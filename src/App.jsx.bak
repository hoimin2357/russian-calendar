otes": "Use to get attention or apologize politely."}, {"id": 7, "date": "2026-01-07", "word": "Здравствуйте", "pronunciation": "ZDRA-stvuy-tye", "ipa": "/ˈzdrastvʊjtʲe/", "meaning": "Hello (formal)", "part_of_speech": "interjection", "category": "Greetings", "cefr_level": "A1", "sentence_ru": "Здравствуйте, меня зовут Иван.", "sentence_en": "Hello, my name is Ivan.", "notes": "Formal greeting. The first 'в' is silent."}, {"id": 8, "date": "2026-01-08", "word": "Я", "pronunciation": "Ya", "ipa": "/ja/", "meaning": "I", "part_of_speech": "pronoun", "category": "Pronouns", "cefr_level": "A1", "sentence_ru": "Я из Америки.", "sentence_en": "I am from America.", "notes": "First letter of the Russian alphabet's last letter — easy to spot."}, {"id": 9, "date": "2026-01-09", "word": "Ты", "pronunciation": "Ty", "ipa": "/tɨ/", "meaning": "You (informal singular)", "part_of_speech": "pronoun", "category": "Pronouns", "cefr_level": "A1", "sentence_ru": "Ты дома?", "sentence_en": "Are you home?", "notes": "Use with friends, family, children only."}, {"id": 10, "date": "2026-01-10", "word": "Вы", "pronunciation": "Vy", "ipa": "/vɨ/", "meaning": "You (formal / plural)", "part_of_speech": "pronoun", "category": "Pronouns", "cefr_level": "A1", "sentence_ru": "Вы говорите по-английски?", "sentence_en": "Do you speak English?", "notes": "Polite singular OR plural. Default for adults you don't know."}, {"id": 11, "date": "2026-01-11", "word": "Он", "pronunciation": "On", "ipa": "/on/", "meaning": "He", "part_of_speech": "pronoun", "category": "Pronouns", "cefr_level": "A1", "sentence_ru": "Он мой брат.", "sentence_en": "He is my brother.", "notes": "Also used for masculine inanimate nouns ('it')."}, {"id": 12, "date": "2026-01-12", "word": "Она", "pronunciation": "A-NA", "ipa": "/ɐˈna/", "meaning": "She", "part_of_speech": "pronoun", "category": "Pronouns", "cefr_level": "A1", "sentence_ru": "Она учитель.", "sentence_en": "She is a teacher.", "notes": "Unstressed 'о' sounds like 'a'.