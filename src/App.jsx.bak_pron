// 各言語のデータ（同じ構造: 219日 A1→A2→B1）
import ruData from './data/ru.json';
import koData from './data/ko.json';
import zhData from './data/zh.json';
import enData from './data/en.json';

// ============================================================
// LANGUAGES — 言語ハブ設定
// ============================================================
const LANGUAGES = [
  { code: 'ru', name: 'Russian',  native: 'Русский',  flag: '🇷🇺', tts: 'ru-RU', data: ruData },
  { code: 'ko', name: 'Korean',   native: '한국어',    flag: '🇰🇷', tts: 'ko-KR', data: koData },
  { code: 'zh', name: 'Chinese',  native: '中文',      flag: '🇨🇳', tts: 'zh-CN', data: zhData },
  { code: 'en', name: 'English',  native: 'English',  flag: '🇬🇧', tts: 'en-GB', data: enData },
];
const getLanguage = (code) => LANGUAGES.find(l => l.code === code) || LANGUAGES[0];

// ============================================================
// SRS ENGINE — Spaced Repetition (間隔反復学習)
// 標準間隔: 1, 3, 7, 15, 30日
// ============================================================
const SRS_INTERVALS = [1, 3, 7, 15, 30];
const MAX_STAGE = SRS_INTERVALS.length - 1;

const srsAddDays = (isoDate, days) => {
  const d = new Date(isoDate);
  d.setDate(d.getDate() + days);
  return d.toISOString().split('T')[0];
};

const createSrsEntry = (seenDate) => ({
  stage: 0,
  nextReview: srsAddDays(seenDate, SRS_INTERVALS[0]),
  seen: seenDate,
  lapses: 0,
  mastered: false,
  lastReviewed: null,
});

const promoteEntry = (entry, reviewDate) => {
  const newStage = Math.min(entry.stage + 1, MAX_STAGE);
  const isMastered = entry.stage >= MAX_STAGE;
  return {
    ...entry,
    stage: newStage,
    nextReview: srsAddDays(reviewDate, SRS_INTERVALS[newStage]),
    mastered: isMastered,
    lastReviewed: reviewDate,
  };
};

const demoteEntry = (entry, reviewDate) => ({
  ...entry,
  stage: 0,
  nextReview: srsAddDays(reviewDate, SRS_INTERVALS[0]),
  lapses: entry.lapses + 1,
  mastered: false,
  lastReviewed: reviewDate,
});

const isDue = (entry, today) => {
  if (!entry || entry.mastered) return false;
  return entry.nextReview <= today;
};

const getStrength = (entry) => {
  if (!entry) return 0;
  if (entry.mastered) return 100;
  return Math.round((entry.stage / (MAX_STAGE + 1)) * 100);
};

// ============================================================
// QUIZ ENGINE — 日曜クイズ（4形式 + その週&過去ミックス）
// ============================================================
const QUIZ_TYPES = ['ru_to_meaning', 'meaning_to_ru', 'listening', 'cloze'];

const quizShuffle = (arr) => {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
};

// ダミー選択肢を生成（正解と重複しない3つ）
const makeDistractors = (correctValue, pool, field, count = 3) => {
  const seen = new Set([correctValue]);
  const result = [];
  for (const w of quizShuffle(pool)) {
    if (!seen.has(w[field])) { seen.add(w[field]); result.push(w[field]); }
    if (result.length >= count) break;
  }
  return result;
};

// 穴埋め可能か（例文に単語がそのまま含まれるか）
const canCloze = (word) => word.sentence_ru && word.sentence_ru.includes(word.word);
const makeCloze = (word) => word.sentence_ru.replace(word.word, '____');

// 1問を生成
const makeQuestion = (word, pool, forcedType = null) => {
  let type = forcedType || QUIZ_TYPES[Math.floor(Math.random() * QUIZ_TYPES.length)];
  if (type === 'cloze' && !canCloze(word)) type = 'ru_to_meaning';

  let question, options, answer, audio = null;
  if (type === 'ru_to_meaning') {
    question = word.word; answer = word.meaning;
    options = quizShuffle([word.meaning, ...makeDistractors(word.meaning, pool, 'meaning')]);
  } else if (type === 'meaning_to_ru') {
    question = word.meaning; answer = word.word;
    options = quizShuffle([word.word, ...makeDistractors(word.word, pool, 'word')]);
  } else if (type === 'listening') {
    question = '🔊'; audio = word.word; answer = word.meaning;
    options = quizShuffle([word.meaning, ...makeDistractors(word.meaning, pool, 'meaning')]);
  } else if (type === 'cloze') {
    question = makeCloze(word); answer = word.word;
    options = quizShuffle([word.word, ...makeDistractors(word.word, pool, 'word')]);
  }
  return { type, question, options, answer, audio, wordId: word.id, fullWord: word };
};

// 週のクイズを生成（その週+過去ミックス）
const generateWeeklyQuiz = (allWords, todayISO, numQuestions = 10) => {
  const weekAgo = new Date(todayISO);
  weekAgo.setDate(weekAgo.getDate() - 7);
  const weekAgoISO = weekAgo.toISOString().split('T')[0];

  const learned = allWords.filter(w => w.day_date <= todayISO);
  if (learned.length === 0) return [];

  const thisWeek = learned.filter(w => w.day_date > weekAgoISO);
  const past = learned.filter(w => w.day_date <= weekAgoISO);

  // 週の単語を優先（最大7問）、残りは過去から
  let selected = quizShuffle(thisWeek).slice(0, Math.min(7, numQuestions));
  const remaining = numQuestions - selected.length;
  if (remaining > 0) {
    selected = [...selected, ...quizShuffle(past).slice(0, remaining)];
  }
  // それでも足りなければ全体から補充
  if (selected.length < numQuestions) {
    const ids = new Set(selected.map(w => w.id));
    const more = quizShuffle(learned).filter(w => !ids.has(w.id)).slice(0, numQuestions - selected.length);
    selected = [...selected, ...more];
  }

  // 形式を均等に割り当て
  return quizShuffle(selected).map((w, i) => makeQuestion(w, learned, QUIZ_TYPES[i % QUIZ_TYPES.length]));
};

// 日曜かどうか
const isSunday = (isoDate) => new Date(isoDate).getDay() === 0;

// ============================================================
// GAMIFICATION — XP / Level / Badges
// ============================================================
const XP_REWARDS = {
  newWord: 5,
  srsCorrect: 10,
  quizCorrect: 10,
  quizPerfect: 50,
  mastered: 30,
  dailyLogin: 20,
};

// レベル計算（Lv L までの累積XP = 100 * L*(L-1)/2）
const xpForLevel = (level) => 100 * level * (level - 1) / 2;
const levelFromXP = (xp) => {
  let lv = 1;
  while (xpForLevel(lv + 1) <= xp) lv++;
  return lv;
};
const levelProgress = (xp) => {
  const lv = levelFromXP(xp);
  const curBase = xpForLevel(lv);
  const nextBase = xpForLevel(lv + 1);
  return {
    level: lv,
    current: xp - curBase,
    needed: nextBase - curBase,
    pct: Math.round(((xp - curBase) / (nextBase - curBase)) * 100),
  };
};

// 称号（英語 + ロシア語）
const TITLES = [
  { min: 1, title: 'Beginner', ru: 'Новичок' },
  { min: 5, title: 'Explorer', ru: 'Исследователь' },
  { min: 10, title: 'Scholar', ru: 'Учёный' },
  { min: 20, title: 'Expert', ru: 'Эксперт' },
  { min: 35, title: 'Master', ru: 'Мастер' },
  { min: 50, title: 'Sage', ru: 'Мудрец' },
];
const titleForLevel = (lv) => {
  let t = TITLES[0];
  for (const x of TITLES) if (lv >= x.min) t = x;
  return t;
};

