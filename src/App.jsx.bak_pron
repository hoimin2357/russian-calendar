// 達成済みバッジを判定
const computeUnlockedBadges = (g) => {
  const u = [];
  if (g.wordsLearned >= 1) u.push('first_word');
  if (g.wordsLearned >= 10) u.push('words_10');
  if (g.wordsLearned >= 50) u.push('words_50');
  if (g.wordsLearned >= 100) u.push('words_100');
  if (g.mastered >= 10) u.push('mastered_10');
  if (g.mastered >= 50) u.push('mastered_50');
  if (g.streak >= 3) u.push('streak_3');
  if (g.streak >= 7) u.push('streak_7');
  if (g.streak >= 30) u.push('streak_30');
  if (g.quizPerfect) u.push('quiz_perfect');
  if (g.quizCount >= 10) u.push('quiz_10');
  if (g.level >= 10) u.push('level_10');
  if (g.duoStreak >= 7) u.push('duo_7');
  return u;
};

// ============================================================
// DUOLINGO COMPANION — 並走モード
// ============================================================
// ペース比較: 今日までに見るべき単語数 vs 実際に見た数
const getPaceStatus = (wordData, actualWordsSeen, todayISO) => {
  const startDate = wordData[0].date;
  const today = new Date(todayISO);
  const start = new Date(startDate);
  const daysPassed = Math.floor((today - start) / (1000 * 60 * 60 * 24)) + 1;

  let expectedWords = 0;
  for (let i = 0; i < Math.min(Math.max(daysPassed, 0), wordData.length); i++) {
    expectedWords += wordData[i].words.length;
  }

  const diff = actualWordsSeen - expectedWords;
  let status, message;
  if (diff >= 5) { status = 'ahead'; message = "You're ahead of schedule! 🚀"; }
  else if (diff >= -2) { status = 'ontrack'; message = "Right on track! 👍"; }
  else { status = 'behind'; message = "A little behind — catch up soon! 💪"; }

  return { daysPassed: Math.max(daysPassed, 0), expectedWords, actualWords: actualWordsSeen, diff, status, message };
};

// Duolingo連続記録（今日から遡って連続でログがある日数）
const getDuoStreak = (duoLog, todayISO) => {
  let streak = 0;
  const d = new Date(todayISO);
  while (true) {
    const iso = d.toISOString().split('T')[0];
    if (duoLog[iso]) { streak++; d.setDate(d.getDate() - 1); }
    else break;
  }
  return streak;
};

// 過去N日間のDuoログをカレンダーグリッドにするためのヘルパー
const getRecentDays = (todayISO, n) => {
  const days = [];
  const d = new Date(todayISO);
  for (let i = 0; i < n; i++) {
    days.unshift(d.toISOString().split('T')[0]);
    d.setDate(d.getDate() - 1);
  }
  return days;
};

// ============================================================
// CONSTANTS & HELPERS
// ============================================================
// localStorageキーのベース名（実際は言語コードが前置される: 例 rcal_ru_srs）
const STORAGE_BASE = {
  LEARNED: 'learned',
  NOT_YET: 'not_yet',
  BOOKMARKED: 'bookmarked',
  LAST_VISIT: 'last_visit',
  STREAK_DATA: 'streak',
  SRS: 'srs',
  GAMIFICATION: 'gamification',
  DUOLINGO: 'duolingo',
};
// 言語別キーを生成（例: rcal_ru_srs）
const langKey = (langCode, base) => `rcal_${langCode}_${base}`;
// 言語に依存しないグローバルキー
const GLOBAL_KEYS = {
  THEME: 'rcal_theme',
  CURRENT_LANG: 'rcal_current_lang',
};

const getTodayISO = () => new Date().toISOString().split('T')[0];

const findTodayIndex = (wordData) => {
  const today = getTodayISO();
  const idx = wordData.findIndex(d => d.date === today);
  if (idx >= 0) return idx;
  const first = wordData[0]?.date;
  const last = wordData[wordData.length - 1]?.date;
  if (today < first) return 0;
  if (today > last) return wordData.length - 1;
  return 0;
};

// ============================================================
// CUSTOM HOOK: localStorage state（key変更に追従）
// ============================================================
function useLocalStorage(key, initial) {
  const [value, setValue] = useState(() => {
    try {
      const stored = localStorage.getItem(key);
      return stored ? JSON.parse(stored) : initial;
    } catch {
      return initial;
    }
  });

  // keyが変わったら、新しいkeyの値を読み込み直す（言語切替対応）
  const prevKey = useRef(key);
  useEffect(() => {
    if (prevKey.current !== key) {
      prevKey.current = key;
      try {
        const stored = localStorage.getItem(key);
        setValue(stored ? JSON.parse(stored) : initial);
      } catch {
        setValue(initial);
      }
    }
  }, [key, initial]);

  // 値が変わったら保存
  useEffect(() => {
    try { localStorage.setItem(key, JSON.stringify(value)); } catch {}
  }, [key, value]);

  return [value, setValue];
}

// ============================================================
// COMPONENT: SmartImage — 言語別画像＋フォールバック
// 探す順: {lang}/{id}.png → ru/{id}.png → 絵文字プレースホルダ
// ============================================================
function SmartImage({ wordId, langCode, meaning, dark }) {
  // 試行するパスの候補（優先順）
  const candidates = useMemo(() => {
    const list = [`/images/${langCode}/${wordId}.png`];
    if (langCode !== 'ru') list.push(`/images/ru/${wordId}.png`); // ロシア語版にフォールバック
    return list;
  }, [wordId, langCode]);

  const [srcIdx, setSrcIdx] = useState(0);
  const [failed, setFailed] = useState(false);

  // wordId/langが変わったらリセット
  useEffect(() => { setSrcIdx(0); setFailed(false); }, [wordId, langCode]);

  if (failed || srcIdx >= candidates.length) {
    // 全部失敗 → 絵文字プレースホルダ
    return (
      <div className="word-image-placeholder">
        <Sparkles size={48} strokeWidth={1.2} />
        <div className="placeholder-text">{meaning.split(/[\/\s,]/)[0]}</div>
      </div>
    );
  }

  return (
    <img
      src={candidates[srcIdx]}
      alt={meaning}
      className="word-image"
      onError={() => {
        // 次の候補へ。全部尽きたらfailed
        if (srcIdx + 1 < candidates.length) setSrcIdx(srcIdx + 1);
        else setFailed(true);
      }}
    />
  );
}

// ============================================================
// COMPONENT: WordCard — main card showing one word
// ============================================================
function WordCard({ word, dayEntry, onSpeak, isLearned, isNotYet, isBookmarked,
                   onMarkLearned, onMarkNotYet, onToggleBookmark, dark, langCode }) {
  const [hidden, setHidden] = useState(false);

  return (
    <div className={`word-card-inner ${dark ? 'dark' : ''}`}>
      {/* Image / Visual */}
      <div className="word-image-area">
        <SmartImage wordId={word.id} langCode={langCode} meaning={word.meaning} dark={dark} />
      </div>

      {/* Russian word */}
      <div className="word-main">
        <h1 className="russian-word">{word.word}</h1>
        <button
          className="speak-btn"
          onClick={() => onSpeak(word.word)}
          title="Speak"
          aria-label="Speak word"
        >
          <Volume2 size={24} />
        </button>
      </div>

      {/* Pronunciation */}
      <div className="pronunciation-row">
        <span className="pron">{word.pronunciation}</span>
        <span className="ipa">{word.ipa}</span>
      </div>

      {/* Meaning (hide/reveal) */}
      <div className="meaning-section">
        {hidden ? (
          <button className="reveal-btn" onClick={() => setHidden(false)}>
            <Eye size={18} /> Tap to reveal meaning
          </button>
        ) : (
          <>
            <div className="meaning-row">
              <p className="meaning">{word.meaning}</p>
              <button className="hide-btn" onClick={() => setHidden(true)} title="Hide meaning">
                <EyeOff size={16} />
              </button>
            </div>
            <p className="part-of-speech">{word.part_of_speech}</p>
          </>
        )}
      </div>

      {/* Example sentence */}
      {!hidden && (
        <div className="example-section">
          <p className="sentence-ru">
            {word.sentence_ru}
            <button
              className="mini-speak"
              onClick={() => onSpeak(word.sentence_ru)}
              title="Speak sentence"
            >
              <Volume2 size={14} />
            </button>
          </p>
          <p className="sentence-en">{word.sentence_en}</p>
        </div>
      )}

      {/* Notes */}
      {!hidden && word.notes && (
        <div className="notes-section">
          <strong>Note:</strong> {word.notes}
        </div>
      )}

      {/* PROMINENT learned / not yet buttons */}
      <div className="recall-buttons">
        <button
          className={`recall-btn learned ${isLearned ? 'active' : ''}`}
          onClick={() => onMarkLearned(word.id)}
        >
          <CheckCircle2 size={22} />
          <span>{isLearned ? 'Learned!' : "I know this"}</span>
        </button>
        <button
          className={`recall-btn notyet ${isNotYet ? 'active' : ''}`}
          onClick={() => onMarkNotYet(word.id)}
        >
          <XCircle size={22} />
          <span>{isNotYet ? 'In Review List' : "Not yet"}</span>
        </button>
      </div>

      {/* Bookmark */}
      <div className="bookmark-row">
        <button
          className={`bookmark-btn ${isBookmarked ? 'active' : ''}`}
          onClick={() => onToggleBookmark(word.id)}
        >
          {isBookmarked ? <BookmarkCheck size={18} /> : <Bookmark size={18} />}
          <span>{isBookmarked ? 'Bookmarked' : 'Bookmark'}</span>
        </button>
      </div>
    </div>
  );
}

// ============================================================
// COMPONENT: DayCard — wraps one day (may have 1+ words)
// ============================================================
function DayCard({ dayEntry, onSpeak, learned, notYet, bookmarked,
                  onMarkLearned, onMarkNotYet, onToggleBookmark, dark, langCode }) {
  const [wordIdx, setWordIdx] = useState(0);

  // reset when day changes
  useEffect(() => { setWordIdx(0); }, [dayEntry.id]);

  const word = dayEntry.words[wordIdx];
  const hasMultiple = dayEntry.words.length > 1;

  const dateObj = new Date(dayEntry.date);
  const dayOfWeek = dateObj.toLocaleDateString('en-US', { weekday: 'long' });
  const dayNumber = dateObj.getDate();
  const monthName = dateObj.toLocaleDateString('en-US', { month: 'long' });
  const isSunday = dateObj.getDay() === 0;

  return (
    <div className="day-card-outer">
      {/* Header strip */}
      <div className="card-header">
        <div className="date-stack">
          <div className="day-number">{dayNumber}</div>
          <div className="month-name">{monthName}</div>
          <div className={`day-of-week ${isSunday ? 'sunday' : ''}`}>{dayOfWeek}</div>
        </div>
        <div className="theme-stack">
          <span className="cefr-badge">{dayEntry.cefr_level}</span>
          <h2 className="theme-name">{dayEntry.theme}</h2>
          <span className="category-name">{dayEntry.category}</span>
        </div>
      </div>

      {/* Multi-word tabs */}
      {hasMultiple && (
        <div className="word-tabs">
          {dayEntry.words.map((w, i) => (
            <button
              key={w.id}
              className={`word-tab ${i === wordIdx ? 'active' : ''} ${learned.includes(w.id) ? 'tab-learned' : ''}`}
              onClick={() => setWordIdx(i)}
            >
              {i + 1}. {w.word}
            </button>
          ))}
        </div>
      )}

      {/* Word card */}
      <WordCard
        word={word}
        dayEntry={dayEntry}
        onSpeak={onSpeak}
        isLearned={learned.includes(word.id)}
        isNotYet={notYet.includes(word.id)}
        isBookmarked={bookmarked.includes(word.id)}
        onMarkLearned={onMarkLearned}
        onMarkNotYet={onMarkNotYet}
        onToggleBookmark={onToggleBookmark}
        dark={dark}
        langCode={langCode}
      />

      {/* Tip — LARGER */}
      <div className="tip-section">
        <div className="tip-header">
          <Sparkles size={18} />
          <span>Tip of the Day</span>
        </div>
        <p className="tip-text">{dayEntry.tip}</p>
      </div>
    </div>
  );
}

// ============================================================
// COMPONENT: ReviewSession — SRS-based flashcard review
// 間隔反復の復習モード（フラッシュカード方式）
// ============================================================
function ReviewSession({ dueWords, srsData, onClose, onSpeak, onAnswer, dark }) {
  const [idx, setIdx] = useState(0);
  const [revealed, setRevealed] = useState(false);
  const [sessionResults, setSessionResults] = useState({ correct: 0, wrong: 0 });
  const [finished, setFinished] = useState(false);

  // セッション開始時の対象単語を固定（途中で変わらないように）
  const [queue] = useState(() => [...dueWords]);

  const current = queue[idx];

  const handleAnswer = (remembered) => {
    onAnswer(current.id, remembered);
    setSessionResults(r => ({
      correct: r.correct + (remembered ? 1 : 0),
      wrong: r.wrong + (remembered ? 0 : 1),
    }));
    // 次のカードへ
    if (idx + 1 < queue.length) {
      setIdx(idx + 1);
      setRevealed(false);
    } else {
      setFinished(true);
    }
  };

  // 対象が0の場合
  if (queue.length === 0) {
    return (
      <div className={`view-overlay ${dark ? 'dark' : ''}`}>
        <div className="view-header">
          <h2><Zap size={22} /> Today's Review</h2>
          <button className="close-btn" onClick={onClose}><X size={22} /></button>
        </div>
        <div className="empty-state">
          <Trophy size={48} strokeWidth={1.2} />
          <p>All caught up! 🎉</p>
          <p className="sub">No words due for review today. Come back tomorrow!</p>
        </div>
      </div>
    );
  }

  // セッション完了画面
  if (finished) {
    const total = sessionResults.correct + sessionResults.wrong;
    const pct = total > 0 ? Math.round((sessionResults.correct / total) * 100) : 0;
    return (
      <div className={`view-overlay ${dark ? 'dark' : ''}`}>
        <div className="view-header">
          <h2><Zap size={22} /> Review Complete</h2>
          <button className="close-btn" onClick={onClose}><X size={22} /></button>
        </div>
        <div className="session-complete">
          <Trophy size={64} strokeWidth={1.2} className="complete-trophy" />
          <h3>Great work! 🎉</h3>
          <div className="session-score">
            <div className="score-item correct">
              <span className="score-num">{sessionResults.correct}</span>
              <span className="score-lbl">Remembered</span>
            </div>
            <div className="score-item wrong">
              <span className="score-num">{sessionResults.wrong}</span>
              <span className="score-lbl">Need practice</span>
            </div>
          </div>
          <div className="session-pct">{pct}% recall rate</div>
          <p className="session-note">
            Words you remembered will return at longer intervals.
            Words you missed will come back tomorrow.
          </p>
          <button className="session-done-btn" onClick={onClose}>Done</button>
        </div>
      </div>
    );
  }

  const entry = srsData[current.id];
  const stageLabel = entry
    ? (entry.mastered ? 'Mastered' : `Stage ${entry.stage + 1}/5 · every ${SRS_INTERVALS[entry.stage]}d`)
    : 'New';

  return (
    <div className={`view-overlay ${dark ? 'dark' : ''}`}>
      <div className="view-header">
        <h2><Zap size={22} /> Review {idx + 1} / {queue.length}</h2>
        <button className="close-btn" onClick={onClose}><X size={22} /></button>
      </div>

      {/* 進捗バー */}
      <div className="review-progress">
        <div className="review-progress-fill" style={{ width: `${(idx / queue.length) * 100}%` }}></div>
      </div>

      <div className="flashcard-area">
        <div className="flashcard">
          <span className="flashcard-stage">{stageLabel}</span>

          {/* 表面: ロシア語 */}
          <div className="flashcard-front">
            <h1 className="flashcard-word">{current.word}</h1>
            <button className="speak-btn" onClick={() => onSpeak(current.word)}>
              <Volume2 size={24} />
            </button>
          </div>

          {/* 裏面: 意味（revealするまで隠す） */}
          {revealed ? (
            <div className="flashcard-back">
              <div className="flashcard-pron">{current.pronunciation} · {current.ipa}</div>
              <div className="flashcard-meaning">{current.meaning}</div>
              <div className="flashcard-sentence">
                {current.sentence_ru}
                <button className="mini-speak" onClick={() => onSpeak(current.sentence_ru)}>
                  <Volume2 size={14} />
                </button>
              </div>
              <div className="flashcard-sentence-en">{current.sentence_en}</div>
            </div>
          ) : (
            <button className="flashcard-reveal" onClick={() => setRevealed(true)}>
              <Eye size={20} /> Tap to reveal the answer
            </button>
          )}
        </div>

        {/* 回答ボタン（revealed後のみ表示） */}
        {revealed && (
          <div className="flashcard-answers">
            <button className="answer-btn wrong" onClick={() => handleAnswer(false)}>
              <RotateCcw size={20} />
              <span>Forgot</span>
              <small>review tomorrow</small>
            </button>
            <button className="answer-btn correct" onClick={() => handleAnswer(true)}>
              <CheckCircle2 size={20} />
              <span>I knew it</span>
              <small>{entry ? `in ${SRS_INTERVALS[Math.min(entry.stage + 1, MAX_STAGE)]}d` : 'next'}</small>
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

// ============================================================
// COMPONENT: QuizSession — 日曜クイズ（4形式ミックス）
// ============================================================
function QuizSession({ allWords, onClose, onSpeak, onQuizComplete, dark }) {
  const [questions, setQuestions] = useState(() => generateWeeklyQuiz(allWords, getTodayISO(), 10));
  const [idx, setIdx] = useState(0);
  const [selected, setSelected] = useState(null);
  const [answered, setAnswered] = useState(false);
  const [score, setScore] = useState(0);
  const [finished, setFinished] = useState(false);
  const [wrongWords, setWrongWords] = useState([]);

  const current = questions[idx];

  // クイズをリセットして再挑戦
  const handleRetry = () => {
    setQuestions(generateWeeklyQuiz(allWords, getTodayISO(), 10));
    setIdx(0);
    setSelected(null);
    setAnswered(false);
    setScore(0);
    setFinished(false);
    setWrongWords([]);
  };

  // 間違えた単語だけ再挑戦
  const handleRetryWrong = () => {
    // 間違えた単語からクイズを作る
    const pool = allWords.filter(w => w.day_date <= getTodayISO());
    const retryQuestions = wrongWords.map((w, i) =>
      makeQuestion(w, pool, QUIZ_TYPES[i % QUIZ_TYPES.length])
    );
    setQuestions(quizShuffle(retryQuestions));
    setIdx(0);
    setSelected(null);
    setAnswered(false);
    setScore(0);
    setFinished(false);
    setWrongWords([]);
  };

  // 聞き取り問題は自動で音声再生
  useEffect(() => {
    if (current && current.type === 'listening' && current.audio) {
      const t = setTimeout(() => onSpeak(current.audio), 400);
      return () => clearTimeout(t);
    }
  }, [current, onSpeak]);

  const handleSelect = (option) => {
    if (answered) return;
    setSelected(option);
    setAnswered(true);
    if (option === current.answer) {
      setScore(s => s + 1);
    } else {
      setWrongWords(w => [...w, current.fullWord]);
    }
  };

  const handleNext = () => {
    if (idx + 1 < questions.length) {
      setIdx(idx + 1);
      setSelected(null);
      setAnswered(false);
    } else {
      setFinished(true);
      // scoreは最新の状態を反映（setScoreは適用済みのはずだが念のため関数で取得）
      setScore(finalScore => {
        if (onQuizComplete) onQuizComplete(finalScore, questions.length);
        return finalScore;
      });
    }
  };

  // 問題がない場合
  if (questions.length === 0) {
    return (
      <div className={`view-overlay ${dark ? 'dark' : ''}`}>
        <div className="view-header">
          <h2><Target size={22} /> Sunday Quiz</h2>
          <button className="close-btn" onClick={onClose}><X size={22} /></button>
        </div>
        <div className="empty-state">
          <BookOpen size={48} strokeWidth={1.2} />
          <p>Not enough words yet!</p>
          <p className="sub">Learn a few words first, then come back for a quiz.</p>
        </div>
      </div>
    );
  }

  // 結果画面
  if (finished) {
    const pct = Math.round((score / questions.length) * 100);
    let medal, message;
    if (pct === 100) { medal = '🏆'; message = 'Perfect! Безупречно!'; }
    else if (pct >= 80) { medal = '🥇'; message = 'Excellent! Отлично!'; }
    else if (pct >= 60) { medal = '🥈'; message = 'Good job! Хорошо!'; }
    else if (pct >= 40) { medal = '🥉'; message = 'Keep practicing! Ещё немного!'; }
    else { medal = '📚'; message = "Don't give up! Не сдавайся!"; }

    return (
      <div className={`view-overlay ${dark ? 'dark' : ''}`}>
        <div className="view-header">
          <h2><Target size={22} /> Quiz Complete</h2>
          <button className="close-btn" onClick={onClose}><X size={22} /></button>
        </div>
        <div className="quiz-result">
          <div className="quiz-medal">{medal}</div>
          <h3>{message}</h3>
          <div className="quiz-score-big">{score} / {questions.length}</div>
          <div className="quiz-pct">{pct}%</div>

          {wrongWords.length > 0 && (
            <div className="quiz-review-section">
              <h4>Words to review:</h4>
              <div className="quiz-wrong-list">
                {wrongWords.map(w => (
                  <div key={w.id} className="quiz-wrong-item">
                    <span className="qw-ru">{w.word}</span>
                    <button className="mini-speak" onClick={() => onSpeak(w.word)}>
                      <Volume2 size={14} />
                    </button>
                    <span className="qw-en">{w.meaning}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          <div className="quiz-result-buttons">
            {wrongWords.length > 0 && (
              <button className="quiz-retry-wrong-btn" onClick={handleRetryWrong}>
                <RotateCcw size={18} /> Retry missed ({wrongWords.length})
              </button>
            )}
            <button className="quiz-retry-btn" onClick={handleRetry}>
              <RefreshCw size={18} /> New quiz
            </button>
            <button className="quiz-done-btn" onClick={onClose}>Done</button>
          </div>
        </div>
      </div>
    );
  }

  // 問題タイプのラベル
  const typeLabels = {
    ru_to_meaning: 'Choose the meaning',
    meaning_to_ru: 'Choose the Russian',
    listening: 'Listening',
    cloze: 'Fill in the blank',
  };

  return (
    <div className={`view-overlay ${dark ? 'dark' : ''}`}>
      <div className="view-header">
        <h2><Target size={22} /> Quiz {idx + 1} / {questions.length}</h2>
        <button className="close-btn" onClick={onClose}><X size={22} /></button>
      </div>

      {/* 進捗バー */}
      <div className="review-progress">
        <div className="review-progress-fill" style={{ width: `${(idx / questions.length) * 100}%` }}></div>
      </div>

      <div className="quiz-area">
        <span className="quiz-type-label">{typeLabels[current.type]}</span>

        {/* 問題 */}
        <div className="quiz-question">
          {current.type === 'listening' ? (
            <button className="quiz-audio-btn" onClick={() => onSpeak(current.audio)}>
              <Volume2 size={48} />
              <span>Tap to play</span>
            </button>
          ) : (
            <h1 className={`quiz-q-text ${current.type === 'cloze' ? 'cloze' : ''}`}>
              {current.question}
            </h1>
          )}
        </div>

        {/* 選択肢 */}
        <div className="quiz-options">
          {current.options.map((opt, i) => {
            let cls = 'quiz-option';
            if (answered) {
              if (opt === current.answer) cls += ' correct';
              else if (opt === selected) cls += ' wrong';
              else cls += ' dimmed';
            }
            return (
              <button key={i} className={cls} onClick={() => handleSelect(opt)} disabled={answered}>
                {opt}
                {answered && opt === current.answer && <CheckCircle2 size={18} />}
                {answered && opt === selected && opt !== current.answer && <XCircle size={18} />}
              </button>
            );
          })}
        </div>

        {/* 次へボタン */}
        {answered && (
          <button className="quiz-next-btn" onClick={handleNext}>
            {idx + 1 < questions.length ? 'Next →' : 'See Results'}
          </button>
        )}
      </div>
    </div>
  );
}

// ============================================================
// COMPONENT: ReviewList — words marked "Not yet"
// ============================================================
function ReviewList({ notYet, allWords, onClose, onSpeak, onMarkLearned, dark }) {
  const reviewWords = useMemo(() => {
    return allWords.filter(w => notYet.includes(w.id));
  }, [notYet, allWords]);

  return (
    <div className={`view-overlay ${dark ? 'dark' : ''}`}>
      <div className="view-header">
        <h2><AlertCircle size={22} /> Need Review ({reviewWords.length})</h2>
        <button className="close-btn" onClick={onClose}><X size={22} /></button>
      </div>
      {reviewWords.length === 0 ? (
        <div className="empty-state">
          <CheckCircle2 size={48} strokeWidth={1.2} />
          <p>No words to review!</p>
          <p className="sub">Words you mark "Not yet" will appear here.</p>
        </div>
      ) : (
        <div className="review-grid">
          {reviewWords.map(w => (
            <div key={w.id} className="review-item">
              <div className="review-word-row">
                <span className="review-ru">{w.word}</span>
                <button className="mini-speak" onClick={() => onSpeak(w.word)}>
                  <Volume2 size={14} />
                </button>
              </div>
              <span className="review-en">{w.meaning}</span>
              <span className="review-pron">{w.pronunciation}</span>
              <button
                className="review-mark-learned"
                onClick={() => onMarkLearned(w.id)}
              >
                <CheckCircle2 size={16} /> Got it!
              </button>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ============================================================
// COMPONENT: BrainManual — neuroscience-based usage guide
// ============================================================
function BrainManual({ onClose, dark }) {
  return (
    <div className={`view-overlay ${dark ? 'dark' : ''}`}>
      <div className="view-header">
        <h2><Brain size={22} /> How Your Brain Learns Russian</h2>
        <button className="close-btn" onClick={onClose}><X size={22} /></button>
      </div>
      <div className="manual-content">
        <section>
          <h3>🧠 Why this calendar works</h3>
          <p>
            This app is built around four principles backed by cognitive
            neuroscience. Following them, you will retain far more than
            with passive study (textbooks, vague exposure).
          </p>
        </section>

        <section>
          <h3>1. Spaced repetition (forgetting curve)</h3>
          <p>
            Your brain forgets ~60% of new information within 24 hours.
            But if you review at expanding intervals — 1 day, 3 days,
            7 days, 15 days, 30 days — memory becomes near-permanent.
          </p>
          <p className="manual-tip">
            👉 <strong>How to use:</strong> Mark words "Not yet" when
            uncertain. Visit the Review list every day. Mark "Got it!"
            only when you feel confident.
          </p>
        </section>

        <section>
          <h3>2. Active recall (not passive reading)</h3>
          <p>
            Research shows recalling information improves retention by
            ~80%, vs. 34% for passive reading. The mental effort to
            retrieve a word strengthens the neural pathway.
          </p>
          <p className="manual-tip">
            👉 <strong>How to use:</strong> Use the eye icon (👁) to hide
            the meaning. Try to remember before revealing. The struggle
            is the learning.
          </p>
        </section>

        <section>
          <h3>3. Picture Superiority Effect</h3>
          <p>
            The brain processes images 60,000x faster than text.
            Pairing a word with a visual image creates a dual-coded
            memory — verbal AND visual — making recall faster.
          </p>
          <p className="manual-tip">
            👉 <strong>How to use:</strong> Look carefully at each
            illustration. When you encounter the word later, the image
            will surface in your mind.
          </p>
        </section>

        <section>
          <h3>4. Sleep consolidates memory</h3>
          <p>
            Studies (Payne et al.) show that vocabulary learned before
            sleep is retained 20-35% better. Sleep allows the
            hippocampus to transfer short-term memories to long-term
            storage.
          </p>
          <p className="manual-tip">
            👉 <strong>How to use:</strong> Review the day's word in
            the evening, just before bed. Your brain will work on it
            while you sleep.
          </p>
        </section>

        <section>
          <h3>📅 Recommended daily routine</h3>
          <ul className="routine-list">
            <li><strong>Morning:</strong> Read today's word + tip. Use the "speak" button. Read the sentence aloud.</li>
            <li><strong>Midday:</strong> Quick check — can you recall the meaning? Mark "I know this" if yes.</li>
            <li><strong>Evening:</strong> Review yesterday's word + the Need Review list. Read example sentence aloud.</li>
            <li><strong>Before bed:</strong> One last glance at today's word. Sleep helps it stick.</li>
          </ul>
        </section>

        <section>
          <h3>🦄 Combine with Duolingo</h3>
          <p>
            This calendar complements Duolingo well. Duolingo is excellent
            for grammar drills and gamified practice. This calendar adds
            deep vocabulary with cultural context, IPA, and brain-science
            backing. Use both daily, ~10 min each.
          </p>
        </section>

        <section>
          <h3>⏰ Missed days?</h3>
          <p>
            Don't worry. When you return, the app shows what you missed.
            Use the calendar (left arrow ⬅) to flip back through skipped
            days. Quality &gt; perfect streak.
          </p>
        </section>
      </div>
    </div>
  );
}

// ============================================================
// COMPONENT: CatchUpBanner — shows when user has missed days
// ============================================================
function CatchUpBanner({ missedDays, onJump, onDismiss }) {
  if (missedDays === 0) return null;
  return (
    <div className="catchup-banner">
      <RefreshCw size={18} />
      <span>You missed {missedDays} day{missedDays > 1 ? 's' : ''}. </span>
      <button className="catchup-btn" onClick={onJump}>Catch up</button>
      <button className="catchup-dismiss" onClick={onDismiss}><X size={16} /></button>
    </div>
  );
}

// ============================================================
// MAIN APP
// ============================================================
export default function App() {
  // ─── 言語選択（グローバル）─────────────────────────────────
  const [langCode, setLangCode] = useLocalStorage(GLOBAL_KEYS.CURRENT_LANG, 'ru');
  const lang = getLanguage(langCode);
  const wordData = lang.data;
  const [showLangPicker, setShowLangPicker] = useState(false);

  // ─── 既存ロシア語データの移行（旧キー → 新キー）────────────
  // 一度だけ実行: rcal_srs → rcal_ru_srs など
  useEffect(() => {
    const migrationDone = localStorage.getItem('rcal_migrated_v7');
    if (migrationDone) return;
    const oldKeys = {
      'rcal_learned': 'rcal_ru_learned',
      'rcal_not_yet': 'rcal_ru_not_yet',
      'rcal_bookmarked': 'rcal_ru_bookmarked',
      'rcal_last_visit': 'rcal_ru_last_visit',
      'rcal_streak': 'rcal_ru_streak',
      'rcal_srs': 'rcal_ru_srs',
      'rcal_gamification': 'rcal_ru_gamification',
      'rcal_duolingo': 'rcal_ru_duolingo',
    };
    try {
      for (const [oldK, newK] of Object.entries(oldKeys)) {
        const val = localStorage.getItem(oldK);
        if (val !== null && localStorage.getItem(newK) === null) {
          localStorage.setItem(newK, val);
        }
      }
      localStorage.setItem('rcal_migrated_v7', 'true');
    } catch {}
  }, []);

  // ─── State（言語ごとに分離）────────────────────────────────
  const [currentIdx, setCurrentIdx] = useState(() => findTodayIndex(wordData));
  const [learned, setLearned] = useLocalStorage(langKey(langCode, STORAGE_BASE.LEARNED), []);
  const [notYet, setNotYet] = useLocalStorage(langKey(langCode, STORAGE_BASE.NOT_YET), []);
  const [bookmarked, setBookmarked] = useLocalStorage(langKey(langCode, STORAGE_BASE.BOOKMARKED), []);
  const [dark, setDark] = useLocalStorage(GLOBAL_KEYS.THEME, false); // テーマはグローバル
  const [lastVisit, setLastVisit] = useLocalStorage(langKey(langCode, STORAGE_BASE.LAST_VISIT), null);
  const [srsData, setSrsData] = useLocalStorage(langKey(langCode, STORAGE_BASE.SRS), {});
  const [gamif, setGamif] = useLocalStorage(langKey(langCode, STORAGE_BASE.GAMIFICATION), {
    xp: 0,
    streak: 0,
    lastStreakDate: null,
    quizCount: 0,
    quizPerfect: false,
    seenBadges: [],
  });
  const [levelUpNotice, setLevelUpNotice] = useState(null);
  const [newBadge, setNewBadge] = useState(null);
  const [duoLog, setDuoLog] = useLocalStorage(langKey(langCode, STORAGE_BASE.DUOLINGO), {});

  const [view, setView] = useState('main');
  const [menuOpen, setMenuOpen] = useState(false);
  const [tearing, setTearing] = useState(null);
  const [showCatchUp, setShowCatchUp] = useState(true);

  // 言語が変わったら今日のインデックスにリセット
  useEffect(() => {
    setCurrentIdx(findTodayIndex(wordData));
    setView('main');
  }, [langCode]);

  const dayEntry = wordData[currentIdx];

  // ─── Catch-up detection ───────────────────────────────────
  const missedDays = useMemo(() => {
    if (!lastVisit) return 0;
    const today = getTodayISO();
    const lastDate = new Date(lastVisit);
    const todayDate = new Date(today);
    const diff = Math.floor((todayDate - lastDate) / (1000 * 60 * 60 * 24));
    return diff > 1 ? diff - 1 : 0;
  }, [lastVisit]);

  useEffect(() => {
    setLastVisit(getTodayISO());
  }, []);

  // ─── All words flat (for review list) ─────────────────────
  const allWords = useMemo(() => {
    return wordData.flatMap(d => d.words.map(w => ({
      ...w,
      day_date: d.date,
      day_theme: d.theme,
    })));
  }, [wordData]);

  // ─── Gamification: XP加算（先に定義：他のeffectから参照されるため）─
  const addXP = useCallback((amount) => {
    setGamif(prev => {
      const before = levelFromXP(prev.xp);
      const after = levelFromXP(prev.xp + amount);
      if (after > before) {
        setTimeout(() => setLevelUpNotice({ level: after, title: titleForLevel(after) }), 100);
      }
      return { ...prev, xp: prev.xp + amount };
    });
  }, [setGamif]);

  // ─── SRS: 表示中の日の単語を自動登録 ───────────────────────
  // 今日（カレンダー上の今日）以前の日を開いたら、その単語をSRSに登録
  useEffect(() => {
    const today = getTodayISO();
    // 未来の単語は登録しない（まだ習っていないので）
    if (dayEntry.date > today) return;

    setSrsData(prev => {
      let newCount = 0;
      const next = { ...prev };
      for (const w of dayEntry.words) {
        if (!next[w.id]) {
          next[w.id] = createSrsEntry(today);
          newCount++;
        }
      }
      if (newCount > 0) {
        // 新しい単語を見たXP
        setTimeout(() => addXP(XP_REWARDS.newWord * newCount), 150);
        return next;
      }
      return prev;
    });
  }, [dayEntry, setSrsData, addXP]);

  // ─── SRS: 今日復習すべき単語 ───────────────────────────────
  const dueWords = useMemo(() => {
    const today = getTodayISO();
    return allWords.filter(w => isDue(srsData[w.id], today));
  }, [allWords, srsData]);

  // ─── SRS: 復習の回答を処理 ─────────────────────────────────
  const handleSrsAnswer = useCallback((wordId, remembered) => {
    const today = getTodayISO();
    setSrsData(prev => {
      const entry = prev[wordId] || createSrsEntry(today);
      const wasMastered = entry.mastered;
      const updated = remembered
        ? promoteEntry(entry, today)
        : demoteEntry(entry, today);
      // XP付与
      if (remembered) {
        let xp = XP_REWARDS.srsCorrect;
        if (updated.mastered && !wasMastered) xp += XP_REWARDS.mastered; // 新規習得ボーナス
        setTimeout(() => addXP(xp), 100);
      }
      return { ...prev, [wordId]: updated };
    });
  }, [setSrsData, addXP]);

  // ─── Quiz: 完了時の処理（XP・統計更新）─────────────────────
  const handleQuizComplete = useCallback((score, total) => {
    const isPerfect = score === total && total > 0;
    let xp = score * XP_REWARDS.quizCorrect;
    if (isPerfect) xp += XP_REWARDS.quizPerfect;
    addXP(xp);
    setGamif(prev => ({
      ...prev,
      quizCount: prev.quizCount + 1,
      quizPerfect: prev.quizPerfect || isPerfect,
    }));
  }, [addXP, setGamif]);

  // ─── SRS: 統計 ─────────────────────────────────────────────
  const srsStats = useMemo(() => {
    const entries = Object.values(srsData);
    const today = getTodayISO();
    return {
      total: entries.length,
      due: entries.filter(e => isDue(e, today)).length,
      mastered: entries.filter(e => e.mastered).length,
      learning: entries.filter(e => !e.mastered).length,
    };
  }, [srsData]);

  // ─── Duolingo: streak（バッジ判定で使うため先に計算）─────
  const duoStreak = useMemo(() => getDuoStreak(duoLog, getTodayISO()), [duoLog]);

  // ─── Gamification: 派生値 ──────────────────────────────────
  const gamifStats = useMemo(() => {
    const prog = levelProgress(gamif.xp);
    const title = titleForLevel(prog.level);
    const badgeStats = {
      wordsLearned: srsStats.total,
      mastered: srsStats.mastered,
      streak: gamif.streak,
      quizPerfect: gamif.quizPerfect,
      quizCount: gamif.quizCount,
      level: prog.level,
      duoStreak: duoStreak,
    };
    const unlocked = computeUnlockedBadges(badgeStats);
    return { ...prog, title, unlocked };
  }, [gamif, srsStats, duoStreak]);

  // ─── Duolingo: ペース & 今日の記録 ─────────────────────────
  const paceStatus = useMemo(
    () => getPaceStatus(wordData, srsStats.total, getTodayISO()),
    [srsStats.total, wordData]
  );
  const duoTodayDone = !!duoLog[getTodayISO()];

  // ─── Duolingo: 今日の記録をトグル ─────────────────────────
  const toggleDuoToday = useCallback(() => {
    const today = getTodayISO();
    setDuoLog(prev => ({ ...prev, [today]: !prev[today] }));
  }, [setDuoLog]);

  // ─── Gamification: デイリーログイン & streak ───────────────
  useEffect(() => {
    const today = getTodayISO();
    setGamif(prev => {
      if (prev.lastStreakDate === today) return prev; // 既に今日ログイン済み
      // 連続判定
      const yesterday = srsAddDays(today, -1);
      let newStreak;
      if (prev.lastStreakDate === yesterday) newStreak = prev.streak + 1;
      else if (prev.lastStreakDate === null) newStreak = 1;
      else newStreak = 1; // 途切れた
      // ログインボーナス
      setTimeout(() => addXP(XP_REWARDS.dailyLogin), 200);
      return { ...prev, streak: newStreak, lastStreakDate: today };
    });
  }, []); // 初回マウントのみ

  // ─── Gamification: 新バッジ検出 ───────────────────────────
  useEffect(() => {
    const unlocked = gamifStats.unlocked;
    const newOnes = unlocked.filter(id => !gamif.seenBadges.includes(id));
    if (newOnes.length > 0) {
      // 最初の新バッジを通知
      const badge = BADGES.find(b => b.id === newOnes[0]);
      setNewBadge(badge);
      setGamif(prev => ({
        ...prev,
        seenBadges: [...new Set([...prev.seenBadges, ...unlocked])],
      }));
    }
  }, [gamifStats.unlocked]);

  // ─── Speech ───────────────────────────────────────────────
  const speak = useCallback((text) => {
    if (!('speechSynthesis' in window)) return;
    window.speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(text);
    u.lang = lang.tts; // 選択中の言語に応じたTTS
    u.rate = 0.85;
    window.speechSynthesis.speak(u);
  }, [lang.tts]);

  // ─── Navigation ───────────────────────────────────────────
  const goPrev = useCallback(() => {
    if (currentIdx > 0) {
      setTearing('left');
      setTimeout(() => {
        setCurrentIdx(i => i - 1);
        setTearing(null);
      }, 250);
    }
  }, [currentIdx]);

  const goNext = useCallback(() => {
    if (currentIdx < wordData.length - 1) {
      setTearing('right');
      setTimeout(() => {
        setCurrentIdx(i => i + 1);
        setTearing(null);
      }, 250);
    }
  }, [currentIdx]);

  const goToday = useCallback(() => {
    // FIX: recompute today's index on click (not just mount)
    const todayIdx = findTodayIndex(wordData);
    setCurrentIdx(todayIdx);
    setView('main');
    setMenuOpen(false);
  }, [wordData]);

  // ─── Keyboard nav ─────────────────────────────────────────
  useEffect(() => {
    const onKey = (e) => {
      if (view !== 'main') return;
      if (e.key === 'ArrowLeft') goPrev();
      else if (e.key === 'ArrowRight') goNext();
      else if (e.key === ' ') {
        e.preventDefault();
      }
    };
    window.addEventListener('keydown', onKey);
    return () => window.removeEventListener('keydown', onKey);
  }, [goPrev, goNext, view]);

  // ─── Mark functions ───────────────────────────────────────
  const markLearned = useCallback((wordId) => {
    setLearned(prev => prev.includes(wordId) ? prev.filter(x => x !== wordId) : [...prev, wordId]);
    setNotYet(prev => prev.filter(x => x !== wordId)); // remove from not-yet
  }, [setLearned, setNotYet]);

  const markNotYet = useCallback((wordId) => {
    setNotYet(prev => prev.includes(wordId) ? prev.filter(x => x !== wordId) : [...prev, wordId]);
    setLearned(prev => prev.filter(x => x !== wordId)); // remove from learned
  }, [setLearned, setNotYet]);

  const toggleBookmark = useCallback((wordId) => {
    setBookmarked(prev => prev.includes(wordId) ? prev.filter(x => x !== wordId) : [...prev, wordId]);
  }, [setBookmarked]);

  // ─── Stats ────────────────────────────────────────────────
  const stats = useMemo(() => ({
    learned: learned.length,
    notYet: notYet.length,
    bookmarked: bookmarked.length,
    total: allWords.length,
    progress: Math.round((learned.length / allWords.length) * 100),
  }), [learned, notYet, bookmarked, allWords]);

  // ─── Render ───────────────────────────────────────────────
  return (
    <div className={`app-root ${dark ? 'dark' : ''}`}>
      <style>{styles}</style>

      {/* ─── Top Bar ─── */}
      <div className="topbar">
        <button className="icon-btn" onClick={() => setMenuOpen(!menuOpen)} aria-label="Menu">
          <Menu size={22} />
        </button>
        <button className="lang-switcher" onClick={() => setShowLangPicker(true)}>
          <span className="lang-flag">{lang.flag}</span>
          <span className="lang-name">{lang.native}</span>
          <ChevronDown size={16} />
        </button>
        <button className="icon-btn" onClick={() => setDark(!dark)} aria-label="Theme">
          {dark ? <Sun size={20} /> : <Moon size={20} />}
        </button>
      </div>

      {/* ─── Language Picker Modal ─── */}
      {showLangPicker && (
        <div className="lang-picker-overlay" onClick={() => setShowLangPicker(false)}>
          <div className="lang-picker" onClick={(e) => e.stopPropagation()}>
            <div className="lang-picker-header">
              <Globe size={20} />
              <span>Choose a language</span>
            </div>
            {LANGUAGES.map(l => (
              <button
                key={l.code}
                className={`lang-option ${l.code === langCode ? 'active' : ''}`}
                onClick={() => {
                  setLangCode(l.code);
                  setShowLangPicker(false);
                }}
              >
                <span className="lang-option-flag">{l.flag}</span>
                <div className="lang-option-text">
                  <span className="lang-option-native">{l.native}</span>
                  <span className="lang-option-name">{l.name}</span>
                </div>
                {l.code === langCode && <CheckCircle2 size={18} />}
              </button>
            ))}
          </div>
        </div>
      )}

      {/* ─── XP Bar (always visible) ─── */}
      <div className="xp-bar-container" onClick={() => { setView('achievements'); setMenuOpen(false); }}>
        <div className="xp-level-badge">
          <Trophy size={14} />
          <span>Lv {gamifStats.level}</span>
        </div>
        <div className="xp-bar-track">
          <div className="xp-bar-fill" style={{ width: `${gamifStats.pct}%` }}></div>
          <span className="xp-bar-label">{gamifStats.title.title} · {gamif.xp} XP</span>
        </div>
        {gamif.streak > 0 && (
          <div className="xp-streak">🔥 {gamif.streak}</div>
        )}
      </div>

      {/* ─── Side Menu ─── */}
      {menuOpen && (
        <div className="side-menu" onClick={() => setMenuOpen(false)}>
          <nav className="menu-content" onClick={(e) => e.stopPropagation()}>
            <button onClick={() => { goToday(); }}>
              <HomeIcon size={18} /> Today
            </button>
            <button onClick={() => { setView('srs'); setMenuOpen(false); }}>
              <Zap size={18} /> Today's Review
              {srsStats.due > 0 && <span className="badge badge-srs">{srsStats.due}</span>}
            </button>
            <button onClick={() => { setView('quiz'); setMenuOpen(false); }}>
              <Target size={18} /> Sunday Quiz
              {isSunday(getTodayISO()) && <span className="badge badge-quiz">today!</span>}
            </button>
            <button onClick={() => { setView('achievements'); setMenuOpen(false); }}>
              <Trophy size={18} /> Achievements
              {gamifStats.unlocked.length > 0 && <span className="badge badge-quiz">{gamifStats.unlocked.length}</span>}
            </button>
            <button onClick={() => { setView('duolingo'); setMenuOpen(false); }}>
              <Layers size={18} /> Duolingo Sync
              {duoStreak > 0 && <span className="badge badge-duo">🦉{duoStreak}</span>}
            </button>
            <button onClick={() => { setView('review'); setMenuOpen(false); }}>
              <AlertCircle size={18} /> Need Review
              {notYet.length > 0 && <span className="badge">{notYet.length}</span>}
            </button>
            <button onClick={() => { setView('manual'); setMenuOpen(false); }}>
              <Brain size={18} /> How Your Brain Learns
            </button>
            <button onClick={() => { setView('stats'); setMenuOpen(false); }}>
              <TrendingUp size={18} /> Progress
            </button>
            <button onClick={() => { setView('index'); setMenuOpen(false); }}>
              <Search size={18} /> Browse All Words
            </button>
          </nav>
        </div>
      )}

      {/* ─── Catch-up banner ─── */}
      {view === 'main' && showCatchUp && missedDays > 0 && (
        <CatchUpBanner
          missedDays={missedDays}
          onJump={() => {
            const lastIdx = wordData.findIndex(d => d.date === lastVisit);
            if (lastIdx >= 0 && lastIdx + 1 < wordData.length) {
              setCurrentIdx(lastIdx + 1);
            }
            setShowCatchUp(false);
          }}
          onDismiss={() => setShowCatchUp(false)}
        />
      )}

      {/* ─── Sunday quiz prompt ─── */}
      {view === 'main' && isSunday(getTodayISO()) && (
        <div className="quiz-prompt" onClick={() => setView('quiz')}>
          <Target size={20} />
          <div className="srs-prompt-text">
            <strong>Sunday Quiz is ready! 🎉</strong>
            <span>Test what you learned this week — 10 questions</span>
          </div>
          <ChevronRight size={20} />
        </div>
      )}

      {/* ─── Duolingo reminder (未記録の時) ─── */}
      {view === 'main' && !duoTodayDone && (
        <div className="duo-reminder" onClick={() => setView('duolingo')}>
          <Layers size={18} />
          <span>Practiced on Duolingo today? Tap to log it 🦉</span>
        </div>
      )}

      {/* ─── Today's review prompt (SRS) ─── */}
      {view === 'main' && dueWords.length > 0 && (
        <div className="srs-prompt" onClick={() => setView('srs')}>
          <Zap size={20} />
          <div className="srs-prompt-text">
            <strong>{dueWords.length} word{dueWords.length > 1 ? 's' : ''} ready to review</strong>
            <span>Tap to start today's spaced-repetition session</span>
          </div>
          <ChevronRight size={20} />
        </div>
      )}

      {/* ─── Main view ─── */}
      {view === 'main' && (
        <div className="card-area">
          <button
            className="nav-arrow nav-left"
            onClick={goPrev}
            disabled={currentIdx === 0}
            aria-label="Previous day"
          >
            <ChevronLeft size={28} />
          </button>

          <div className={`card-wrap ${tearing ? `tearing-${tearing}` : ''}`}>
            <DayCard
              dayEntry={dayEntry}
              onSpeak={speak}
              learned={learned}
              notYet={notYet}
              bookmarked={bookmarked}
              onMarkLearned={markLearned}
              onMarkNotYet={markNotYet}
              onToggleBookmark={toggleBookmark}
              dark={dark}
              langCode={langCode}
            />
          </div>

          <button
            className="nav-arrow nav-right"
            onClick={goNext}
            disabled={currentIdx === wordData.length - 1}
            aria-label="Next day"
          >
            <ChevronRight size={28} />
          </button>
        </div>
      )}

      {/* ─── SRS Review Session view ─── */}
      {view === 'srs' && (
        <ReviewSession
          dueWords={dueWords}
          srsData={srsData}
          onClose={() => setView('main')}
          onSpeak={speak}
          onAnswer={handleSrsAnswer}
          dark={dark}
        />
      )}

      {/* ─── Sunday Quiz view ─── */}
      {view === 'quiz' && (
        <QuizSession
          allWords={allWords}
          onClose={() => setView('main')}
          onSpeak={speak}
          onQuizComplete={handleQuizComplete}
          dark={dark}
        />
      )}

      {/* ─── Achievements view ─── */}
      {view === 'achievements' && (
        <div className={`view-overlay ${dark ? 'dark' : ''}`}>
          <div className="view-header">
            <h2><Trophy size={22} /> Achievements</h2>
            <button className="close-btn" onClick={() => setView('main')}><X size={22} /></button>
          </div>
          <div className="achievements-content">
            {/* レベルカード */}
            <div className="level-card">
              <div className="level-card-top">
                <div className="level-big">
                  <Trophy size={28} />
                  <span>Level {gamifStats.level}</span>
                </div>
                <div className="level-title">
                  {gamifStats.title.title}
                  <span className="level-title-ru">{gamifStats.title.ru}</span>
                </div>
              </div>
              <div className="level-xp-track">
                <div className="level-xp-fill" style={{ width: `${gamifStats.pct}%` }}></div>
              </div>
              <div className="level-xp-text">
                {gamifStats.current} / {gamifStats.needed} XP to Level {gamifStats.level + 1}
              </div>
              <div className="level-total-xp">{gamif.xp} total XP</div>
            </div>

            {/* streak + クイズ統計 */}
            <div className="achieve-mini-grid">
              <div className="achieve-mini">
                <div className="achieve-mini-num">🔥 {gamif.streak}</div>
                <div className="achieve-mini-lbl">Day Streak</div>
              </div>
              <div className="achieve-mini">
                <div className="achieve-mini-num">🎯 {gamif.quizCount}</div>
                <div className="achieve-mini-lbl">Quizzes Done</div>
              </div>
              <div className="achieve-mini">
                <div className="achieve-mini-num">🏆 {srsStats.mastered}</div>
                <div className="achieve-mini-lbl">Words Mastered</div>
              </div>
            </div>

            {/* バッジ一覧 */}
            <h3 className="badges-title">Badges ({gamifStats.unlocked.length} / {BADGES.length})</h3>
            <div className="badges-grid">
              {BADGES.map(badge => {
                const isUnlocked = gamifStats.unlocked.includes(badge.id);
                return (
                  <div key={badge.id} className={`badge-item ${isUnlocked ? 'unlocked' : 'locked'}`}>
                    <div className="badge-icon">{isUnlocked ? badge.icon : '🔒'}</div>
                    <div className="badge-name">{badge.name}</div>
                    <div className="badge-name-ru">{badge.ru}</div>
                    <div className="badge-desc">{badge.desc}</div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* ─── Duolingo Sync view ─── */}
      {view === 'duolingo' && (
        <div className={`view-overlay ${dark ? 'dark' : ''}`}>
          <div className="view-header">
            <h2><Layers size={22} /> Duolingo Sync</h2>
            <button className="close-btn" onClick={() => setView('main')}><X size={22} /></button>
          </div>
          <div className="duo-content">
            {/* 今日の記録トグル */}
            <div className="duo-today-card">
              <div className="duo-today-text">
                <strong>Did you practice on Duolingo today?</strong>
                <span>Track both apps to build a dual streak</span>
              </div>
              <button
                className={`duo-toggle ${duoTodayDone ? 'done' : ''}`}
                onClick={toggleDuoToday}
              >
                {duoTodayDone ? <><CheckCircle2 size={20} /> Done!</> : 'Mark done'}
              </button>
            </div>

            {/* デュアルストリーク */}
            <div className="duo-streak-card">
              <div className="duo-streak-num">🦉 {duoStreak}</div>
              <div className="duo-streak-lbl">
                Day{duoStreak !== 1 ? 's' : ''} using both apps in a row
              </div>
              {duoStreak >= 7 && <div className="duo-badge-note">🏆 Dual Power badge unlocked!</div>}
            </div>

            {/* ペース比較 (B) */}
            <div className="duo-pace-section">
              <h3 className="duo-section-title">Your Pace</h3>
              <div className={`duo-pace-card ${paceStatus.status}`}>
                <div className="duo-pace-message">{paceStatus.message}</div>
                <div className="duo-pace-numbers">
                  <div className="duo-pace-item">
                    <span className="dp-num">{paceStatus.actualWords}</span>
                    <span className="dp-lbl">words seen</span>
                  </div>
                  <div className="duo-pace-vs">vs</div>
                  <div className="duo-pace-item">
                    <span className="dp-num">{paceStatus.expectedWords}</span>
                    <span className="dp-lbl">on schedule</span>
                  </div>
                </div>
                <div className="duo-pace-day">Day {paceStatus.daysPassed} of your journey</div>
              </div>
            </div>

            {/* 過去2週間のログ (A) */}
            <div className="duo-log-section">
              <h3 className="duo-section-title">Last 14 Days</h3>
              <div className="duo-log-grid">
                {getRecentDays(getTodayISO(), 14).map(iso => {
                  const done = !!duoLog[iso];
                  const dayNum = new Date(iso).getDate();
                  const isToday = iso === getTodayISO();
                  return (
                    <div
                      key={iso}
                      className={`duo-log-day ${done ? 'done' : ''} ${isToday ? 'today' : ''}`}
                      onClick={() => setDuoLog(prev => ({ ...prev, [iso]: !prev[iso] }))}
                      title={iso}
                    >
                      {done ? '🦉' : dayNum}
                    </div>
                  );
                })}
              </div>
              <p className="duo-log-hint">Tap any day to toggle your Duolingo record</p>
            </div>

            {/* 役割分担ガイド (D) */}
            <div className="duo-guide-section">
              <h3 className="duo-section-title">How they work together</h3>
              <div className="duo-guide-grid">
                <div className="duo-guide-card duolingo">
                  <div className="duo-guide-icon">🦉</div>
                  <h4>Duolingo</h4>
                  <p>Grammar drills, sentence structure, gamified daily practice</p>
                </div>
                <div className="duo-guide-card calendar">
                  <div className="duo-guide-icon">📖</div>
                  <h4>Russian Daily</h4>
                  <p>Deep vocabulary, cultural context, IPA, spaced repetition</p>
                </div>
              </div>
              <p className="duo-guide-tip">
                💡 Best results: ~10 min on each, every day. Duolingo for active
                practice, Russian Daily for vocabulary depth and long-term memory.
              </p>
            </div>
          </div>
        </div>
      )}
      {view === 'review' && (
        <ReviewList
          notYet={notYet}
          allWords={allWords}
          onClose={() => setView('main')}
          onSpeak={speak}
          onMarkLearned={markLearned}
          dark={dark}
        />
      )}

      {/* ─── Manual view ─── */}
      {view === 'manual' && (
        <BrainManual
          onClose={() => setView('main')}
          dark={dark}
        />
      )}

      {/* ─── Stats view ─── */}
      {view === 'stats' && (
        <div className={`view-overlay ${dark ? 'dark' : ''}`}>
          <div className="view-header">
            <h2><TrendingUp size={22} /> Your Progress</h2>
            <button className="close-btn" onClick={() => setView('main')}><X size={22} /></button>
          </div>
          <div className="stats-content">
            <div className="stat-big-card">
              <div className="stat-num">{stats.learned}</div>
              <div className="stat-lbl">Words Learned</div>
            </div>
            <div className="stat-bar">
              <div className="stat-bar-fill" style={{width: `${stats.progress}%`}}></div>
              <span className="stat-bar-text">{stats.progress}% complete ({stats.learned} / {stats.total})</span>
            </div>
            <div className="stat-mini-grid">
              <div><div className="mini-num">{stats.notYet}</div><div className="mini-lbl">To Review</div></div>
              <div><div className="mini-num">{stats.bookmarked}</div><div className="mini-lbl">Bookmarked</div></div>
              <div><div className="mini-num">{currentIdx + 1}</div><div className="mini-lbl">Day Number</div></div>
            </div>

            {/* SRS統計 */}
            <div className="srs-stats-section">
              <h3 className="srs-stats-title"><Zap size={18} /> Spaced Repetition</h3>
              <div className="stat-mini-grid">
                <div className="srs-stat-due">
                  <div className="mini-num">{srsStats.due}</div>
                  <div className="mini-lbl">Due Today</div>
                </div>
                <div className="srs-stat-learning">
                  <div className="mini-num">{srsStats.learning}</div>
                  <div className="mini-lbl">Learning</div>
                </div>
                <div className="srs-stat-mastered">
                  <div className="mini-num">{srsStats.mastered}</div>
                  <div className="mini-lbl">Mastered 🏆</div>
                </div>
              </div>
              {srsStats.due > 0 && (
                <button className="srs-start-btn" onClick={() => setView('srs')}>
                  <Zap size={18} /> Start Review ({srsStats.due})
                </button>
              )}
            </div>
          </div>
        </div>
      )}

      {/* ─── Index view ─── */}
      {view === 'index' && (
        <div className={`view-overlay ${dark ? 'dark' : ''}`}>
          <div className="view-header">
            <h2><Search size={22} /> All Words</h2>
            <button className="close-btn" onClick={() => setView('main')}><X size={22} /></button>
          </div>
          <div className="index-list">
            {wordData.map((d, idx) => (
              <div key={d.id} className="index-day" onClick={() => { setCurrentIdx(idx); setView('main'); }}>
                <div className="index-date">{d.date}</div>
                <div className="index-theme">{d.theme}</div>
                <div className="index-words">
                  {d.words.map(w => w.word).join(' · ')}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ─── Footer date strip ─── */}
      {view === 'main' && (
        <div className="footer-strip">
          <span>Day {currentIdx + 1} of {wordData.length}</span>
          <button className="today-btn" onClick={goToday}>
            <Calendar size={14} /> Today
          </button>
        </div>
      )}

      {/* ─── Level-up notification ─── */}
      {levelUpNotice && (
        <div className="toast-overlay" onClick={() => setLevelUpNotice(null)}>
          <div className="toast-card levelup" onClick={(e) => e.stopPropagation()}>
            <div className="toast-icon">🎉</div>
            <div className="toast-title">Level Up!</div>
            <div className="toast-level">Level {levelUpNotice.level}</div>
            <div className="toast-subtitle">
              {levelUpNotice.title.title} · {levelUpNotice.title.ru}
            </div>
            <button className="toast-btn" onClick={() => setLevelUpNotice(null)}>
              Continue
            </button>
          </div>
        </div>
      )}

      {/* ─── New badge notification ─── */}
      {newBadge && (
        <div className="toast-overlay" onClick={() => setNewBadge(null)}>
          <div className="toast-card badge-toast" onClick={(e) => e.stopPropagation()}>
            <div className="toast-icon">{newBadge.icon}</div>
            <div className="toast-title">Badge Unlocked!</div>
            <div className="toast-level">{newBadge.name}</div>
            <div className="toast-subtitle">{newBadge.ru}</div>
            <div className="toast-desc">{newBadge.desc}</div>
            <button className="toast-btn" onClick={() => setNewBadge(null)}>
              Awesome!
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

// ============================================================
// STYLES (inline CSS)
// ============================================================
const styles = `
@import url('https://fonts.googleapis.com/css2?family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=Inter:wght@400;500;600;700&display=swap');

* { box-sizing: border-box; }

.app-root {
  font-family: 'Inter', -apple-system, sans-serif;
  background: #f5efe3;
  min-height: 100vh;
  color: #2c1810;
  position: relative;
}
.app-root.dark {
  background: #1a1612;
  color: #e8dcc6;
}

/* ─── Topbar ─── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px;
  background: rgba(245, 239, 227, 0.95);
  border-bottom: 1px solid #d4c4a8;
  position: sticky; top: 0; z-index: 100;
  backdrop-filter: blur(8px);
}
.dark .topbar {
  background: rgba(26, 22, 18, 0.95);
  border-bottom-color: #3a2f24;
}
.app-title {
  display: flex; align-items: center; gap: 8px;
  font-weight: 700; font-size: 16px;
}
.icon-btn {
  background: none; border: none; padding: 8px; cursor: pointer;
  color: inherit; border-radius: 6px; display: flex; align-items: center;
}
.icon-btn:hover { background: rgba(139, 38, 38, 0.08); }

/* ─── Side menu ─── */
.side-menu {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4);
  z-index: 200; animation: fadeIn 0.15s ease;
}
.menu-content {
  background: #f5efe3; width: 280px; height: 100%; padding: 60px 0 20px;
  display: flex; flex-direction: column; gap: 4px;
  box-shadow: 4px 0 24px rgba(0,0,0,0.2);
  animation: slideRight 0.2s ease;
}
.dark .menu-content { background: #1a1612; }
.menu-content button {
  background: none; border: none; padding: 14px 24px; text-align: left;
  font-size: 15px; cursor: pointer; color: inherit;
  display: flex; align-items: center; gap: 12px;
  position: relative;
}
.menu-content button:hover { background: rgba(139, 38, 38, 0.08); }
.menu-content .badge {
  position: absolute; right: 24px; background: #8b2626; color: white;
  font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 700;
}
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes slideRight { from { transform: translateX(-100%); } to { transform: translateX(0); } }

/* ─── Catch-up banner ─── */
.catchup-banner {
  display: flex; align-items: center; gap: 10px;
  background: #fff4d6; padding: 10px 16px; margin: 12px 16px;
  border-radius: 8px; border-left: 4px solid #c9a45a;
  font-size: 14px;
}
.dark .catchup-banner {
  background: #3a2f1a; border-left-color: #c9a45a;
}
.catchup-btn {
  margin-left: auto; background: #8b2626; color: white;
  border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer;
  font-size: 13px; font-weight: 600;
}
.catchup-dismiss {
  background: none; border: none; color: inherit; cursor: pointer; padding: 4px;
  display: flex; align-items: center;
}

/* ─── Main card area ─── */
.card-area {
  display: flex; align-items: stretch; justify-content: center;
  padding: 24px 16px; max-width: 900px; margin: 0 auto;
  gap: 12px;
}
.card-wrap {
  flex: 1; min-width: 0;
  transition: transform 0.25s ease, opacity 0.25s ease;
}
.card-wrap.tearing-left {
  transform: translateX(-30px) rotate(-2deg); opacity: 0.4;
}
.card-wrap.tearing-right {
  transform: translateX(30px) rotate(2deg); opacity: 0.4;
}
.nav-arrow {
  background: rgba(139, 38, 38, 0.08); border: none; color: #8b2626;
  cursor: pointer; padding: 12px; border-radius: 50%;
  display: flex; align-items: center;
  align-self: center;
  transition: background 0.15s;
}
.nav-arrow:hover:not(:disabled) { background: rgba(139, 38, 38, 0.18); }
.nav-arrow:disabled { opacity: 0.3; cursor: not-allowed; }
.dark .nav-arrow { color: #d4a574; background: rgba(212, 165, 116, 0.1); }

/* ─── Day Card ─── */
.day-card-outer {
  background: #faf6ee;
  border: 1px solid #d4c4a8;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 4px 24px rgba(60, 30, 10, 0.08);
  position: relative;
}
.dark .day-card-outer {
  background: #25201b;
  border-color: #3a2f24;
}

/* ─── Header ─── */
.card-header {
  display: flex; gap: 16px; align-items: flex-start;
  border-bottom: 1px dashed #d4c4a8; padding-bottom: 14px; margin-bottom: 16px;
}
.dark .card-header { border-bottom-color: #3a2f24; }
.date-stack {
  flex-shrink: 0; text-align: center; padding: 4px 14px;
  border-right: 1px dashed #d4c4a8;
}
.dark .date-stack { border-right-color: #3a2f24; }
.day-number {
  font-family: 'Old Standard TT', serif; font-size: 44px; font-weight: 700;
  color: #8b2626; line-height: 1;
}
.dark .day-number { color: #d4a574; }
.month-name {
  font-size: 12px; text-transform: uppercase; letter-spacing: 1px;
  font-weight: 600; margin-top: 2px;
}
.day-of-week {
  font-size: 11px; color: #6b5848; margin-top: 4px;
}
.day-of-week.sunday {
  color: #8b2626; font-weight: 600;
}
.dark .day-of-week { color: #a89684; }
.theme-stack { flex: 1; padding-top: 4px; }
.cefr-badge {
  display: inline-block; background: #8b2626; color: white;
  padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 700;
}
.theme-name {
  font-family: 'Old Standard TT', serif;
  font-size: 22px; font-weight: 700; margin: 6px 0 4px;
  color: #3c1e0a;
}
.dark .theme-name { color: #e8dcc6; }
.category-name {
  font-size: 12px; color: #6b5848; font-style: italic;
}
.dark .category-name { color: #a89684; }

/* ─── Word tabs ─── */
.word-tabs {
  display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px;
}
.word-tab {
  background: rgba(139, 38, 38, 0.08); color: #8b2626;
  border: 1px solid transparent;
  padding: 6px 12px; border-radius: 16px; font-size: 13px;
  cursor: pointer; font-weight: 500;
  transition: all 0.15s;
}
.word-tab:hover { background: rgba(139, 38, 38, 0.15); }
.word-tab.active {
  background: #8b2626; color: white; border-color: #8b2626;
}
.word-tab.tab-learned::after {
  content: ' ✓'; opacity: 0.7;
}
.dark .word-tab { background: rgba(212, 165, 116, 0.15); color: #d4a574; }
.dark .word-tab.active { background: #d4a574; color: #25201b; }

/* ─── Word card inner ─── */
.word-card-inner { padding: 4px 0; }
.word-image-area {
  width: 100%; aspect-ratio: 16/9;
  background: rgba(139, 38, 38, 0.05);
  border-radius: 8px; margin-bottom: 16px;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
.dark .word-image-area { background: rgba(212, 165, 116, 0.08); }
.word-image { width: 100%; height: 100%; object-fit: cover; }
.word-image-placeholder {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: #8b2626; opacity: 0.5;
}
.dark .word-image-placeholder { color: #d4a574; }
.placeholder-text {
  font-family: 'Old Standard TT', serif; font-size: 18px; font-style: italic;
}

.word-main {
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  margin-bottom: 6px;
}
.russian-word {
  font-family: 'Old Standard TT', serif;
  font-size: 48px; font-weight: 700; margin: 0;
  color: #3c1e0a; line-height: 1.1;
}
.dark .russian-word { color: #f4e4c1; }
.speak-btn {
  background: #8b2626; color: white; border: none;
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: transform 0.15s;
}
.speak-btn:hover { transform: scale(1.1); }
.dark .speak-btn { background: #d4a574; color: #25201b; }

.pronunciation-row {
  display: flex; gap: 12px; align-items: baseline; flex-wrap: wrap;
  margin-bottom: 14px;
}
.pron {
  font-size: 15px; color: #6b5848; font-style: italic;
}
.ipa {
  font-size: 13px; color: #8b6b48; font-family: monospace;
}
.dark .pron { color: #c4b29a; }
.dark .ipa { color: #d4a574; }

.meaning-section {
  background: rgba(139, 38, 38, 0.05);
  border-radius: 8px; padding: 12px 14px; margin-bottom: 12px;
}
.dark .meaning-section { background: rgba(212, 165, 116, 0.08); }
.meaning-row { display: flex; align-items: flex-start; gap: 8px; }
.meaning {
  flex: 1; font-size: 20px; font-weight: 600; margin: 0; color: #3c1e0a;
}
.dark .meaning { color: #f4e4c1; }
.hide-btn {
  background: none; border: none; padding: 4px; cursor: pointer;
  color: #8b6b48; opacity: 0.6; display: flex; align-items: center;
}
.hide-btn:hover { opacity: 1; }
.part-of-speech {
  font-size: 12px; color: #8b6b48; margin: 4px 0 0;
  text-transform: lowercase; font-style: italic;
}
.reveal-btn {
  background: rgba(139, 38, 38, 0.1); border: 1px dashed #8b2626;
  color: #8b2626; padding: 12px 16px; border-radius: 6px;
  width: 100%; cursor: pointer; font-size: 14px; font-weight: 500;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.dark .reveal-btn {
  border-color: #d4a574; color: #d4a574; background: rgba(212, 165, 116, 0.1);
}

.example-section {
  border-left: 3px solid #c9a45a; padding-left: 12px; margin-bottom: 12px;
}
.sentence-ru {
  font-family: 'Old Standard TT', serif;
  font-size: 18px; margin: 0 0 4px; font-style: italic;
  display: flex; align-items: center; gap: 8px;
}
.mini-speak {
  background: none; border: 1px solid #c9a45a; color: #8b6b48;
  width: 24px; height: 24px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
}
.mini-speak:hover { background: rgba(201, 164, 90, 0.15); }
.sentence-en {
  font-size: 13px; color: #6b5848; margin: 0;
}
.dark .sentence-en { color: #c4b29a; }

.notes-section {
  background: rgba(201, 164, 90, 0.1);
  border-radius: 6px; padding: 10px 12px;
  font-size: 13px; margin-bottom: 14px;
  color: #6b5848;
}
.dark .notes-section { background: rgba(201, 164, 90, 0.15); color: #c4b29a; }

/* ─── Recall buttons (BIG, PROMINENT) ─── */
.recall-buttons {
  display: flex; gap: 8px; margin: 16px 0 12px;
}
.recall-btn {
  flex: 1; padding: 14px 12px; border: 2px solid;
  background: white; border-radius: 8px; cursor: pointer;
  font-size: 14px; font-weight: 600;
  display: flex; flex-direction: column; align-items: center; gap: 6px;
  transition: all 0.15s;
}
.dark .recall-btn { background: #2a241e; }
.recall-btn.learned {
  border-color: #4a7c4a; color: #4a7c4a;
}
.recall-btn.learned:hover, .recall-btn.learned.active {
  background: #4a7c4a; color: white;
}
.recall-btn.notyet {
  border-color: #c9a45a; color: #a07a30;
}
.recall-btn.notyet:hover, .recall-btn.notyet.active {
  background: #c9a45a; color: white;
}

.bookmark-row { display: flex; }
.bookmark-btn {
  background: none; border: 1px solid #c9a45a; color: #8b6b48;
  padding: 6px 12px; border-radius: 16px; cursor: pointer; font-size: 13px;
  display: flex; align-items: center; gap: 6px;
  margin-left: auto;
}
.bookmark-btn.active { background: #c9a45a; color: white; }

/* ─── Tip section (LARGER text per request) ─── */
.tip-section {
  background: linear-gradient(135deg, rgba(201, 164, 90, 0.1), rgba(139, 38, 38, 0.05));
  border-radius: 8px; padding: 14px 16px; margin-top: 16px;
  border-left: 4px solid #c9a45a;
}
.tip-header {
  display: flex; align-items: center; gap: 6px; font-size: 13px;
  font-weight: 700; color: #8b6b48; text-transform: uppercase;
  letter-spacing: 1px; margin-bottom: 8px;
}
.dark .tip-header { color: #c9a45a; }
.tip-text {
  font-size: 16px;     /* LARGER per request */
  line-height: 1.6;
  margin: 0;
  color: #3c1e0a;
}
.dark .tip-text { color: #e8dcc6; }

/* ─── Footer ─── */
.footer-strip {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 24px; max-width: 900px; margin: 0 auto;
  font-size: 13px; color: #6b5848;
}
.dark .footer-strip { color: #a89684; }
.today-btn {
  background: #8b2626; color: white; border: none;
  padding: 6px 14px; border-radius: 16px; cursor: pointer;
  font-size: 13px; font-weight: 600;
  display: flex; align-items: center; gap: 6px;
}
.dark .today-btn { background: #d4a574; color: #25201b; }

/* ─── Overlay views ─── */
.view-overlay {
  position: fixed; inset: 0; background: #f5efe3;
  z-index: 150; overflow-y: auto; padding: 0 0 40px;
}
.view-overlay.dark { background: #1a1612; color: #e8dcc6; }
.view-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16px 24px; border-bottom: 1px solid #d4c4a8;
  background: inherit; position: sticky; top: 0; z-index: 5;
}
.dark .view-header { border-bottom-color: #3a2f24; }
.view-header h2 {
  margin: 0; font-size: 20px; font-family: 'Old Standard TT', serif;
  display: flex; align-items: center; gap: 10px;
}
.close-btn {
  background: none; border: none; padding: 6px; cursor: pointer;
  color: inherit; border-radius: 6px;
  display: flex; align-items: center;
}
.close-btn:hover { background: rgba(139, 38, 38, 0.1); }

/* ─── Review list ─── */
.review-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 14px; padding: 20px;
}
.review-item {
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 8px; padding: 14px;
  display: flex; flex-direction: column; gap: 6px;
}
.dark .review-item { background: #25201b; border-color: #3a2f24; }
.review-word-row { display: flex; align-items: center; gap: 8px; }
.review-ru {
  font-family: 'Old Standard TT', serif; font-size: 22px;
  font-weight: 700; color: #8b2626;
}
.dark .review-ru { color: #d4a574; }
.review-en { font-size: 14px; font-weight: 500; }
.review-pron { font-size: 12px; color: #8b6b48; font-style: italic; }
.review-mark-learned {
  margin-top: 6px;
  background: rgba(74, 124, 74, 0.1); border: 1px solid #4a7c4a;
  color: #4a7c4a; padding: 6px 10px; border-radius: 4px;
  cursor: pointer; font-size: 13px; font-weight: 600;
  display: flex; align-items: center; gap: 6px; justify-content: center;
}
.review-mark-learned:hover { background: #4a7c4a; color: white; }

.empty-state {
  display: flex; flex-direction: column; align-items: center;
  padding: 60px 20px; gap: 12px; color: #6b5848;
}
.empty-state .sub { font-size: 13px; opacity: 0.7; }

/* ─── Manual ─── */
.manual-content {
  max-width: 720px; margin: 0 auto; padding: 24px;
}
.manual-content section {
  margin-bottom: 28px; padding-bottom: 20px;
  border-bottom: 1px dashed #d4c4a8;
}
.dark .manual-content section { border-bottom-color: #3a2f24; }
.manual-content section:last-child { border-bottom: none; }
.manual-content h3 {
  font-family: 'Old Standard TT', serif; font-size: 20px;
  color: #8b2626; margin: 0 0 10px;
}
.dark .manual-content h3 { color: #d4a574; }
.manual-content p {
  font-size: 15px; line-height: 1.7; margin: 0 0 10px;
}
.manual-tip {
  background: rgba(201, 164, 90, 0.1);
  border-left: 3px solid #c9a45a;
  padding: 10px 14px; border-radius: 4px;
  font-size: 14px !important;
}
.routine-list { font-size: 15px; line-height: 1.9; padding-left: 20px; }

/* ─── Stats ─── */
.stats-content {
  max-width: 600px; margin: 0 auto; padding: 24px;
  display: flex; flex-direction: column; gap: 20px;
}
.stat-big-card {
  background: linear-gradient(135deg, #8b2626, #6b1818);
  color: white; padding: 32px; border-radius: 12px;
  text-align: center;
}
.dark .stat-big-card { background: linear-gradient(135deg, #d4a574, #b08654); color: #25201b; }
.stat-num { font-size: 48px; font-weight: 700; font-family: 'Old Standard TT', serif; }
.stat-lbl { font-size: 14px; opacity: 0.9; text-transform: uppercase; letter-spacing: 2px; }
.stat-bar {
  background: #d4c4a8; height: 24px; border-radius: 12px;
  position: relative; overflow: hidden;
}
.dark .stat-bar { background: #3a2f24; }
.stat-bar-fill {
  background: #4a7c4a; height: 100%; transition: width 0.3s;
}
.stat-bar-text {
  position: absolute; inset: 0; display: flex; align-items: center;
  justify-content: center; font-size: 13px; font-weight: 600; color: #2c1810;
}
.dark .stat-bar-text { color: #e8dcc6; }
.stat-mini-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
}
.stat-mini-grid > div {
  background: #faf6ee; padding: 16px; border-radius: 8px;
  text-align: center; border: 1px solid #d4c4a8;
}
.dark .stat-mini-grid > div { background: #25201b; border-color: #3a2f24; }
.mini-num { font-size: 28px; font-weight: 700; color: #8b2626; }
.dark .mini-num { color: #d4a574; }
.mini-lbl { font-size: 12px; color: #6b5848; }

/* ─── Index ─── */
.index-list {
  max-width: 700px; margin: 0 auto; padding: 20px;
  display: flex; flex-direction: column; gap: 8px;
}
.index-day {
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 6px; padding: 10px 14px; cursor: pointer;
  display: grid; grid-template-columns: 100px 1fr 2fr; gap: 12px;
  align-items: center; font-size: 13px;
}
.dark .index-day { background: #25201b; border-color: #3a2f24; }
.index-day:hover { background: rgba(139, 38, 38, 0.05); }
.index-date { font-family: monospace; color: #8b6b48; }
.index-theme { font-weight: 600; }
.index-words { color: #6b5848; font-style: italic; }
.dark .index-words { color: #a89684; }

/* ─── SRS: Review prompt banner ─── */
.srs-prompt {
  display: flex; align-items: center; gap: 12px;
  max-width: 900px; margin: 16px auto 0; padding: 14px 18px;
  background: linear-gradient(135deg, #8b2626, #6b1818);
  color: #fff; border-radius: 10px; cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 16px rgba(139, 38, 38, 0.25);
}
.srs-prompt:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(139, 38, 38, 0.35); }
.dark .srs-prompt { background: linear-gradient(135deg, #d4a574, #b08654); color: #25201b; }
.srs-prompt-text { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.srs-prompt-text strong { font-size: 15px; }
.srs-prompt-text span { font-size: 12px; opacity: 0.85; }

.badge-srs { background: #c9a45a !important; }

/* ─── SRS: Flashcard ─── */
.review-progress {
  height: 4px; background: #d4c4a8; margin: 0;
}
.dark .review-progress { background: #3a2f24; }
.review-progress-fill {
  height: 100%; background: #8b2626; transition: width 0.3s;
}
.dark .review-progress-fill { background: #d4a574; }

.flashcard-area {
  max-width: 600px; margin: 0 auto; padding: 24px 16px;
}
.flashcard {
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 16px; padding: 32px 24px;
  box-shadow: 0 4px 24px rgba(60, 30, 10, 0.1);
  position: relative; min-height: 280px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
}
.dark .flashcard { background: #25201b; border-color: #3a2f24; }
.flashcard-stage {
  position: absolute; top: 14px; right: 16px;
  font-size: 11px; color: #8b6b48; background: rgba(201, 164, 90, 0.15);
  padding: 3px 10px; border-radius: 10px;
}
.dark .flashcard-stage { color: #c9a45a; }
.flashcard-front {
  display: flex; align-items: center; gap: 14px; margin-bottom: 20px;
}
.flashcard-word {
  font-family: 'Old Standard TT', serif; font-size: 52px;
  font-weight: 700; color: #3c1e0a; margin: 0;
}
.dark .flashcard-word { color: #f4e4c1; }
.flashcard-reveal {
  background: rgba(139, 38, 38, 0.08); border: 1px dashed #8b2626;
  color: #8b2626; padding: 16px 20px; border-radius: 10px;
  cursor: pointer; font-size: 15px; font-weight: 500;
  display: flex; align-items: center; gap: 8px;
}
.dark .flashcard-reveal { border-color: #d4a574; color: #d4a574; }
.flashcard-back {
  text-align: center; animation: fadeIn 0.2s ease;
}
.flashcard-pron {
  font-size: 14px; color: #8b6b48; font-style: italic; margin-bottom: 10px;
}
.flashcard-meaning {
  font-size: 26px; font-weight: 600; color: #3c1e0a; margin-bottom: 16px;
}
.dark .flashcard-meaning { color: #f4e4c1; }
.flashcard-sentence {
  font-family: 'Old Standard TT', serif; font-size: 18px;
  font-style: italic; margin-bottom: 4px;
  display: flex; align-items: center; gap: 8px; justify-content: center;
}
.flashcard-sentence-en { font-size: 13px; color: #6b5848; }
.dark .flashcard-sentence-en { color: #a89684; }

.flashcard-answers {
  display: flex; gap: 12px; margin-top: 20px;
}
.answer-btn {
  flex: 1; padding: 16px; border: 2px solid; border-radius: 12px;
  background: #faf6ee; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  font-size: 15px; font-weight: 600; transition: all 0.15s;
}
.dark .answer-btn { background: #2a241e; }
.answer-btn small { font-size: 11px; opacity: 0.7; font-weight: 400; }
.answer-btn.wrong { border-color: #c9a45a; color: #a07a30; }
.answer-btn.wrong:hover { background: #c9a45a; color: #fff; }
.answer-btn.correct { border-color: #4a7c4a; color: #4a7c4a; }
.answer-btn.correct:hover { background: #4a7c4a; color: #fff; }

/* ─── SRS: Session complete ─── */
.session-complete {
  max-width: 480px; margin: 0 auto; padding: 40px 24px;
  text-align: center; display: flex; flex-direction: column;
  align-items: center; gap: 16px;
}
.complete-trophy { color: #c9a45a; }
.session-complete h3 {
  font-family: 'Old Standard TT', serif; font-size: 26px; margin: 0;
}
.session-score { display: flex; gap: 32px; margin: 12px 0; }
.score-item { display: flex; flex-direction: column; }
.score-num { font-size: 40px; font-weight: 700; font-family: 'Old Standard TT', serif; }
.score-item.correct .score-num { color: #4a7c4a; }
.score-item.wrong .score-num { color: #c9a45a; }
.score-lbl { font-size: 12px; color: #6b5848; }
.session-pct {
  font-size: 18px; font-weight: 600; color: #8b2626;
}
.dark .session-pct { color: #d4a574; }
.session-note {
  font-size: 13px; color: #6b5848; line-height: 1.6; max-width: 360px;
}
.dark .session-note { color: #a89684; }
.session-done-btn {
  background: #8b2626; color: #fff; border: none;
  padding: 12px 32px; border-radius: 20px; cursor: pointer;
  font-size: 15px; font-weight: 600; margin-top: 8px;
}
.dark .session-done-btn { background: #d4a574; color: #25201b; }

/* ─── SRS: Stats section ─── */
.srs-stats-section {
  margin-top: 8px; padding-top: 20px;
  border-top: 1px dashed #d4c4a8;
}
.dark .srs-stats-section { border-top-color: #3a2f24; }
.srs-stats-title {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Old Standard TT', serif; font-size: 18px;
  color: #8b2626; margin: 0 0 14px;
}
.dark .srs-stats-title { color: #d4a574; }
.srs-stat-due .mini-num { color: #8b2626; }
.srs-stat-mastered .mini-num { color: #4a7c4a; }
.dark .srs-stat-due .mini-num { color: #d4a574; }
.srs-start-btn {
  width: 100%; margin-top: 14px;
  background: #8b2626; color: #fff; border: none;
  padding: 14px; border-radius: 10px; cursor: pointer;
  font-size: 15px; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.dark .srs-start-btn { background: #d4a574; color: #25201b; }

/* ─── Quiz: prompt banner ─── */
.quiz-prompt {
  display: flex; align-items: center; gap: 12px;
  max-width: 900px; margin: 16px auto 0; padding: 14px 18px;
  background: linear-gradient(135deg, #4a7c4a, #3a6a3a);
  color: #fff; border-radius: 10px; cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 16px rgba(74, 124, 74, 0.25);
}
.quiz-prompt:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(74, 124, 74, 0.35); }
.badge-quiz { background: #4a7c4a !important; font-size: 10px !important; }

/* ─── Quiz: area ─── */
.quiz-area {
  max-width: 560px; margin: 0 auto; padding: 24px 16px;
}
.quiz-type-label {
  display: inline-block; font-size: 12px; color: #8b6b48;
  background: rgba(201, 164, 90, 0.15); padding: 4px 12px;
  border-radius: 12px; margin-bottom: 16px;
}
.dark .quiz-type-label { color: #c9a45a; }
.quiz-question {
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 16px; padding: 36px 24px; margin-bottom: 20px;
  text-align: center; min-height: 120px;
  display: flex; align-items: center; justify-content: center;
}
.dark .quiz-question { background: #25201b; border-color: #3a2f24; }
.quiz-q-text {
  font-family: 'Old Standard TT', serif; font-size: 38px;
  font-weight: 700; color: #3c1e0a; margin: 0;
}
.dark .quiz-q-text { color: #f4e4c1; }
.quiz-q-text.cloze { font-size: 26px; line-height: 1.4; }
.quiz-audio-btn {
  background: #8b2626; color: #fff; border: none;
  border-radius: 16px; padding: 24px 32px; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  font-size: 14px;
}
.dark .quiz-audio-btn { background: #d4a574; color: #25201b; }

.quiz-options {
  display: flex; flex-direction: column; gap: 10px;
}
.quiz-option {
  background: #faf6ee; border: 2px solid #d4c4a8;
  border-radius: 12px; padding: 16px 18px; cursor: pointer;
  font-size: 17px; text-align: left; transition: all 0.15s;
  display: flex; align-items: center; justify-content: space-between;
  color: #3c1e0a;
}
.dark .quiz-option { background: #25201b; border-color: #3a2f24; color: #e8dcc6; }
.quiz-option:hover:not(:disabled) { border-color: #8b2626; background: rgba(139, 38, 38, 0.04); }
.quiz-option.correct {
  border-color: #4a7c4a; background: rgba(74, 124, 74, 0.12); color: #4a7c4a; font-weight: 600;
}
.quiz-option.wrong {
  border-color: #c0392b; background: rgba(192, 57, 43, 0.12); color: #c0392b; font-weight: 600;
}
.quiz-option.dimmed { opacity: 0.5; }
.quiz-next-btn {
  width: 100%; margin-top: 20px;
  background: #8b2626; color: #fff; border: none;
  padding: 16px; border-radius: 12px; cursor: pointer;
  font-size: 16px; font-weight: 600;
}
.dark .quiz-next-btn { background: #d4a574; color: #25201b; }

/* ─── Quiz: result ─── */
.quiz-result {
  max-width: 480px; margin: 0 auto; padding: 32px 24px;
  text-align: center; display: flex; flex-direction: column; align-items: center; gap: 12px;
}
.quiz-medal { font-size: 72px; line-height: 1; }
.quiz-result h3 {
  font-family: 'Old Standard TT', serif; font-size: 24px; margin: 0;
}
.quiz-score-big {
  font-size: 44px; font-weight: 700; font-family: 'Old Standard TT', serif;
  color: #8b2626;
}
.dark .quiz-score-big { color: #d4a574; }
.quiz-pct { font-size: 18px; color: #6b5848; }
.quiz-review-section {
  width: 100%; margin-top: 16px; text-align: left;
  background: rgba(201, 164, 90, 0.08); border-radius: 10px; padding: 16px;
}
.quiz-review-section h4 {
  margin: 0 0 12px; font-size: 14px; color: #8b6b48;
}
.dark .quiz-review-section h4 { color: #c9a45a; }
.quiz-wrong-list { display: flex; flex-direction: column; gap: 8px; }
.quiz-wrong-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 0; border-bottom: 1px dashed #d4c4a8;
}
.dark .quiz-wrong-item { border-bottom-color: #3a2f24; }
.qw-ru {
  font-family: 'Old Standard TT', serif; font-size: 18px;
  font-weight: 700; color: #8b2626;
}
.dark .qw-ru { color: #d4a574; }
.qw-en { font-size: 14px; color: #6b5848; }
.dark .qw-en { color: #a89684; }
.quiz-done-btn {
  background: #8b2626; color: #fff; border: none;
  padding: 14px 40px; border-radius: 24px; cursor: pointer;
  font-size: 16px; font-weight: 600; margin-top: 16px;
}
.dark .quiz-done-btn { background: #d4a574; color: #25201b; }

/* ─── Quiz: retry buttons ─── */
.quiz-result-buttons {
  display: flex; flex-direction: column; gap: 10px;
  width: 100%; margin-top: 16px;
}
.quiz-retry-wrong-btn {
  background: rgba(192, 57, 43, 0.1); border: 2px solid #c0392b;
  color: #c0392b; padding: 14px; border-radius: 12px; cursor: pointer;
  font-size: 15px; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.quiz-retry-wrong-btn:hover { background: #c0392b; color: #fff; }
.quiz-retry-btn {
  background: rgba(74, 124, 74, 0.1); border: 2px solid #4a7c4a;
  color: #4a7c4a; padding: 14px; border-radius: 12px; cursor: pointer;
  font-size: 15px; font-weight: 600;
  display: flex; align-items: center; justify-content: center; gap: 8px;
}
.quiz-retry-btn:hover { background: #4a7c4a; color: #fff; }

/* ─── XP Bar (always visible) ─── */
.xp-bar-container {
  display: flex; align-items: center; gap: 10px;
  max-width: 900px; margin: 0 auto; padding: 8px 16px;
  cursor: pointer; border-bottom: 1px solid #d4c4a8;
}
.dark .xp-bar-container { border-bottom-color: #3a2f24; }
.xp-level-badge {
  display: flex; align-items: center; gap: 4px;
  background: #8b2626; color: #fff; padding: 4px 10px;
  border-radius: 12px; font-size: 12px; font-weight: 700;
  flex-shrink: 0;
}
.dark .xp-level-badge { background: #d4a574; color: #25201b; }
.xp-bar-track {
  flex: 1; height: 20px; background: #e5d9c3; border-radius: 10px;
  position: relative; overflow: hidden;
}
.dark .xp-bar-track { background: #3a2f24; }
.xp-bar-fill {
  height: 100%; background: linear-gradient(90deg, #c9a45a, #8b2626);
  transition: width 0.5s ease; border-radius: 10px;
}
.dark .xp-bar-fill { background: linear-gradient(90deg, #d4a574, #c9a45a); }
.xp-bar-label {
  position: absolute; inset: 0; display: flex; align-items: center;
  justify-content: center; font-size: 11px; font-weight: 600;
  color: #3c1e0a; white-space: nowrap;
}
.dark .xp-bar-label { color: #e8dcc6; }
.xp-streak {
  font-size: 13px; font-weight: 700; flex-shrink: 0;
}

/* ─── Achievements page ─── */
.achievements-content {
  max-width: 640px; margin: 0 auto; padding: 20px 16px;
}
.level-card {
  background: linear-gradient(135deg, #8b2626, #6b1818);
  color: #fff; border-radius: 16px; padding: 24px;
  margin-bottom: 20px;
}
.dark .level-card { background: linear-gradient(135deg, #d4a574, #b08654); color: #25201b; }
.level-card-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 16px;
}
.level-big {
  display: flex; align-items: center; gap: 8px;
  font-size: 24px; font-weight: 700; font-family: 'Old Standard TT', serif;
}
.level-title {
  text-align: right; font-size: 18px; font-weight: 600;
  display: flex; flex-direction: column;
}
.level-title-ru { font-size: 13px; opacity: 0.8; font-style: italic; }
.level-xp-track {
  height: 12px; background: rgba(255,255,255,0.25);
  border-radius: 6px; overflow: hidden; margin-bottom: 8px;
}
.dark .level-xp-track { background: rgba(0,0,0,0.15); }
.level-xp-fill {
  height: 100%; background: #fff; border-radius: 6px; transition: width 0.5s;
}
.dark .level-xp-fill { background: #25201b; }
.level-xp-text { font-size: 13px; opacity: 0.9; }
.level-total-xp { font-size: 12px; opacity: 0.7; margin-top: 4px; }

.achieve-mini-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  margin-bottom: 24px;
}
.achieve-mini {
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 12px; padding: 16px; text-align: center;
}
.dark .achieve-mini { background: #25201b; border-color: #3a2f24; }
.achieve-mini-num { font-size: 24px; font-weight: 700; }
.achieve-mini-lbl { font-size: 11px; color: #6b5848; margin-top: 4px; }
.dark .achieve-mini-lbl { color: #a89684; }

.badges-title {
  font-family: 'Old Standard TT', serif; font-size: 20px;
  color: #8b2626; margin: 0 0 16px;
}
.dark .badges-title { color: #d4a574; }
.badges-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 12px;
}
.badge-item {
  border-radius: 12px; padding: 16px 12px; text-align: center;
  border: 1px solid #d4c4a8; transition: transform 0.15s;
}
.dark .badge-item { border-color: #3a2f24; }
.badge-item.unlocked {
  background: #faf6ee;
}
.dark .badge-item.unlocked { background: #25201b; }
.badge-item.unlocked:hover { transform: translateY(-3px); }
.badge-item.locked {
  background: rgba(0,0,0,0.03); opacity: 0.55;
}
.dark .badge-item.locked { background: rgba(255,255,255,0.03); }
.badge-icon { font-size: 36px; margin-bottom: 8px; }
.badge-name { font-size: 13px; font-weight: 700; }
.badge-name-ru { font-size: 11px; color: #8b6b48; font-style: italic; margin-bottom: 6px; }
.dark .badge-name-ru { color: #c9a45a; }
.badge-desc { font-size: 11px; color: #6b5848; line-height: 1.4; }
.dark .badge-desc { color: #a89684; }

/* ─── Toast notifications (level up / badge) ─── */
.toast-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.6);
  z-index: 300; display: flex; align-items: center; justify-content: center;
  animation: fadeIn 0.2s ease; padding: 20px;
}
.toast-card {
  background: #faf6ee; border-radius: 20px; padding: 32px 28px;
  text-align: center; max-width: 340px; width: 100%;
  animation: toastPop 0.4s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  box-shadow: 0 12px 48px rgba(0,0,0,0.3);
}
.dark .toast-card { background: #25201b; }
.toast-card.levelup { border: 3px solid #c9a45a; }
.toast-card.badge-toast { border: 3px solid #8b2626; }
.dark .toast-card.badge-toast { border-color: #d4a574; }
.toast-icon { font-size: 64px; line-height: 1; margin-bottom: 12px; }
.toast-title {
  font-size: 14px; text-transform: uppercase; letter-spacing: 2px;
  color: #8b6b48; font-weight: 700;
}
.dark .toast-title { color: #c9a45a; }
.toast-level {
  font-family: 'Old Standard TT', serif; font-size: 30px;
  font-weight: 700; color: #8b2626; margin: 6px 0;
}
.dark .toast-level { color: #d4a574; }
.toast-subtitle { font-size: 16px; font-weight: 600; }
.toast-desc { font-size: 13px; color: #6b5848; margin-top: 8px; }
.dark .toast-desc { color: #a89684; }
.toast-btn {
  margin-top: 20px; background: #8b2626; color: #fff; border: none;
  padding: 12px 32px; border-radius: 20px; cursor: pointer;
  font-size: 15px; font-weight: 600;
}
.dark .toast-btn { background: #d4a574; color: #25201b; }
@keyframes toastPop {
  from { transform: scale(0.7); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

/* ─── Duolingo Sync ─── */
.badge-duo { background: #58cc02 !important; font-size: 10px !important; }
.duo-reminder {
  display: flex; align-items: center; gap: 10px;
  max-width: 900px; margin: 16px auto 0; padding: 12px 18px;
  background: rgba(88, 204, 2, 0.12); border: 1px dashed #58cc02;
  color: #3a8a00; border-radius: 10px; cursor: pointer; font-size: 14px;
  transition: background 0.15s;
}
.duo-reminder:hover { background: rgba(88, 204, 2, 0.2); }
.dark .duo-reminder { color: #7ed321; background: rgba(88, 204, 2, 0.1); }

.duo-content {
  max-width: 640px; margin: 0 auto; padding: 20px 16px;
}
.duo-today-card {
  display: flex; align-items: center; gap: 16px;
  background: #faf6ee; border: 1px solid #d4c4a8;
  border-radius: 14px; padding: 20px; margin-bottom: 16px;
}
.dark .duo-today-card { background: #25201b; border-color: #3a2f24; }
.duo-today-text { flex: 1; display: flex; flex-direction: column; gap: 4px; }
.duo-today-text strong { font-size: 15px; }
.duo-today-text span { font-size: 12px; color: #6b5848; }
.dark .duo-today-text span { color: #a89684; }
.duo-toggle {
  background: #58cc02; color: #fff; border: none;
  padding: 12px 20px; border-radius: 12px; cursor: pointer;
  font-size: 14px; font-weight: 700; flex-shrink: 0;
  display: flex; align-items: center; gap: 6px;
  transition: all 0.15s;
}
.duo-toggle:hover { background: #4aa802; }
.duo-toggle.done { background: #3a8a00; }

.duo-streak-card {
  text-align: center; background: linear-gradient(135deg, #58cc02, #3a8a00);
  color: #fff; border-radius: 14px; padding: 24px; margin-bottom: 20px;
}
.duo-streak-num { font-size: 44px; font-weight: 700; font-family: 'Old Standard TT', serif; }
.duo-streak-lbl { font-size: 13px; opacity: 0.9; }
.duo-badge-note { margin-top: 8px; font-size: 13px; font-weight: 600; }

.duo-section-title {
  font-family: 'Old Standard TT', serif; font-size: 18px;
  color: #8b2626; margin: 0 0 12px;
}
.dark .duo-section-title { color: #d4a574; }

.duo-pace-section { margin-bottom: 24px; }
.duo-pace-card {
  border-radius: 14px; padding: 20px; border: 2px solid;
}
.duo-pace-card.ahead { border-color: #58cc02; background: rgba(88, 204, 2, 0.08); }
.duo-pace-card.ontrack { border-color: #c9a45a; background: rgba(201, 164, 90, 0.08); }
.duo-pace-card.behind { border-color: #e08a3c; background: rgba(224, 138, 60, 0.08); }
.duo-pace-message { font-size: 17px; font-weight: 600; margin-bottom: 14px; text-align: center; }
.duo-pace-numbers {
  display: flex; align-items: center; justify-content: center; gap: 20px;
}
.duo-pace-item { display: flex; flex-direction: column; align-items: center; }
.dp-num { font-size: 32px; font-weight: 700; font-family: 'Old Standard TT', serif; color: #8b2626; }
.dark .dp-num { color: #d4a574; }
.dp-lbl { font-size: 11px; color: #6b5848; }
.dark .dp-lbl { color: #a89684; }
.duo-pace-vs { font-size: 14px; color: #8b6b48; font-style: italic; }
.duo-pace-day { text-align: center; font-size: 12px; color: #6b5848; margin-top: 12px; }
.dark .duo-pace-day { color: #a89684; }

.duo-log-section { margin-bottom: 24px; }
.duo-log-grid {
  display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px;
}
.duo-log-day {
  aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
  background: #ece2d0; border-radius: 8px; cursor: pointer;
  font-size: 14px; font-weight: 600; color: #8b6b48;
  transition: all 0.15s;
}
.dark .duo-log-day { background: #2a241e; color: #a89684; }
.duo-log-day:hover { transform: scale(1.08); }
.duo-log-day.done { background: rgba(88, 204, 2, 0.2); }
.duo-log-day.today { border: 2px solid #8b2626; }
.dark .duo-log-day.today { border-color: #d4a574; }
.duo-log-hint { font-size: 12px; color: #6b5848; text-align: center; margin-top: 10px; }
.dark .duo-log-hint { color: #a89684; }

.duo-guide-section { margin-bottom: 12px; }
.duo-guide-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 14px;
}
.duo-guide-card {
  border-radius: 14px; padding: 18px; text-align: center; border: 1px solid #d4c4a8;
}
.dark .duo-guide-card { border-color: #3a2f24; }
.duo-guide-card.duolingo { background: rgba(88, 204, 2, 0.08); }
.duo-guide-card.calendar { background: rgba(139, 38, 38, 0.06); }
.duo-guide-icon { font-size: 32px; margin-bottom: 8px; }
.duo-guide-card h4 { margin: 0 0 8px; font-size: 15px; }
.duo-guide-card p { font-size: 12px; color: #6b5848; line-height: 1.5; margin: 0; }
.dark .duo-guide-card p { color: #a89684; }
.duo-guide-tip {
  background: rgba(201, 164, 90, 0.1); border-radius: 10px; padding: 14px;
  font-size: 13px; line-height: 1.6; color: #6b5848;
}
.dark .duo-guide-tip { color: #c4b29a; }

/* ─── Mobile ─── */
@media (max-width: 600px) {
  .card-area { padding: 12px 8px; gap: 6px; }
  .nav-arrow { padding: 8px; }
  .day-card-outer { padding: 14px; }
  .russian-word { font-size: 38px; }
  .meaning { font-size: 17px; }
  .tip-text { font-size: 15px; }
  .index-day { grid-template-columns: 80px 1fr; }
  .index-words { grid-column: 1 / -1; padding-top: 4px; }
  .stat-mini-grid { grid-template-columns: 1fr; }
  .flashcard-word { font-size: 42px; }
  .flashcard-meaning { font-size: 22px; }
  .srs-prompt { margin: 12px 8px 0; }
  .quiz-prompt { margin: 12px 8px 0; }
  .quiz-q-text { font-size: 32px; }
  .quiz-q-text.cloze { font-size: 22px; }
  .quiz-option { font-size: 16px; padding: 14px; }
  .quiz-medal { font-size: 60px; }
  .badges-grid { grid-template-columns: repeat(2, 1fr); }
  .achieve-mini-grid { grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .achieve-mini { padding: 12px 6px; }
  .achieve-mini-num { font-size: 18px; }
  .xp-bar-label { font-size: 10px; }
  .duo-guide-grid { grid-template-columns: 1fr; }
  .duo-today-card { flex-direction: column; align-items: stretch; text-align: center; }
}

/* ─── Language Switcher ─── */
.lang-switcher {
  display: flex; align-items: center; gap: 6px;
  background: rgba(139, 38, 38, 0.08); border: none;
  padding: 6px 14px; border-radius: 18px; cursor: pointer;
  color: inherit; font-size: 15px; font-weight: 600;
  font-family: 'Old Standard TT', serif;
}
.lang-switcher:hover { background: rgba(139, 38, 38, 0.15); }
.dark .lang-switcher { background: rgba(212, 165, 116, 0.12); }
.lang-flag { font-size: 18px; }
.lang-name { font-size: 15px; }

.lang-picker-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  z-index: 250; display: flex; align-items: center; justify-content: center;
  animation: fadeIn 0.2s ease; padding: 20px;
}
.lang-picker {
  background: #faf6ee; border-radius: 20px; padding: 12px;
  max-width: 360px; width: 100%;
  animation: toastPop 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  box-shadow: 0 12px 48px rgba(0,0,0,0.3);
}
.dark .lang-picker { background: #25201b; }
.lang-picker-header {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 16px; font-size: 16px; font-weight: 700;
  color: #8b2626; font-family: 'Old Standard TT', serif;
}
.dark .lang-picker-header { color: #d4a574; }
.lang-option {
  display: flex; align-items: center; gap: 14px; width: 100%;
  background: none; border: none; padding: 14px 16px; cursor: pointer;
  border-radius: 12px; color: inherit; transition: background 0.15s;
}
.lang-option:hover { background: rgba(139, 38, 38, 0.06); }
.dark .lang-option:hover { background: rgba(212, 165, 116, 0.08); }
.lang-option.active { background: rgba(139, 38, 38, 0.1); }
.dark .lang-option.active { background: rgba(212, 165, 116, 0.12); }
.lang-option-flag { font-size: 32px; }
.lang-option-text { flex: 1; display: flex; flex-direction: column; text-align: left; }
.lang-option-native {
  font-size: 18px; font-weight: 700; font-family: 'Old Standard TT', serif;
}
.lang-option-name { font-size: 12px; color: #6b5848; }
.dark .lang-option-name { color: #a89684; }
.lang-option.active { color: #8b2626; }
.dark .lang-option.active { color: #d4a574; }
`;
